<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="seq_kob_shipment" model="ir.sequence">
        <field name="name">KOB Shipment</field>
        <field name="code">kob.shipment</field>
        <field name="prefix">%(year)s</field>
        <field name="padding">6</field>
    </record>
    <record id="seq_kob_return" model="ir.sequence">
        <field name="name">KOB Return Request</field>
        <field name="code">kob.return.request</field>
        <field name="prefix">%(year)s</field>
        <field name="padding">5</field>
    </record>
</odoo>
