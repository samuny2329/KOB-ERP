<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="cron_track_shipments" model="ir.cron">
        <field name="name">KOB: Track Active Shipments</field>
        <field name="cron_name">KOB: Track Active Shipments</field>
        <field name="model_id" ref="model_kob_shipment"/>
        <field name="state">code</field>
        <field name="code">model.cron_track_active()</field>
        <field name="interval_number">30</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>

    <record id="cron_attribution_monthly" model="ir.cron">
        <field name="name">KOB: Compute Monthly Attribution Report</field>
        <field name="cron_name">KOB: Compute Monthly Attribution Report</field>
        <field name="model_id" ref="model_kob_attribution_report"/>
        <field name="state">code</field>
        <field name="code">model.cron_compute_monthly()</field>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
