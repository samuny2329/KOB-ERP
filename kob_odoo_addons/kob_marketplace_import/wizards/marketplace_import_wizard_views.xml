<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="view_marketplace_import_wizard_form" model="ir.ui.view">
            <field name="name">kob.marketplace.import.wizard.form</field>
            <field name="model">kob.marketplace.import.wizard</field>
            <field name="arch" type="xml">
                <form string="Import Marketplace Orders">
                    <sheet>
                        <h1 invisible="state == 'done'">Import Marketplace Orders</h1>
                        <h1 invisible="state != 'done'">Import — Result</h1>
                        <group invisible="state == 'done'">
                            <group>
                                <field name="platform" widget="radio"/>
                                <field name="company_id" groups="base.group_multi_company"/>
                                <field name="warehouse_id"/>
                            </group>
                            <group>
                                <field name="auto_confirm"/>
                                <field name="auto_assign" invisible="not auto_confirm"/>
                                <field name="auto_create_product"/>
                            </group>
                        </group>
                        <group invisible="state == 'done'" string="Source Files">
                            <field name="filename" invisible="1"/>
                            <label for="file_data" string="Single file"/>
                            <div>
                                <field name="file_data" filename="filename" widget="binary"/>
                                <span class="text-muted small">— or use the batch field below.</span>
                            </div>
                            <field name="attachment_ids"
                                   string="Batch (drop folder here)"
                                   widget="many2many_binary"/>
                            <p class="text-muted" colspan="2">
                                Each file must include columns:
                                <b>Order ID</b> (or order_sn / order_no / order_number),
                                <b>SKU</b>, <b>Quantity</b>, [optional]
                                <b>Order Date</b>, <b>Unit Price</b>.
                                Brand + shop are auto-derived from the filename
                                (e.g. <code>Shopee_KissMyBody&#8230;.xlsx</code>).
                                Platform per file is auto-detected (Shopee /
                                Lazada / TikTok); the Platform radio above is
                                the fallback only.
                            </p>
                        </group>
                        <div invisible="state == 'draft'"
                             style="margin: 12px 0;">
                            <label for="progress_pct" string="Progress"/>
                            <field name="progress_pct" widget="progressbar"
                                   nolabel="1"/>
                            <span class="text-muted small">
                                <field name="progress_done" readonly="1"
                                       class="oe_inline"/>
                                / <field name="progress_total" readonly="1"
                                         class="oe_inline"/> orders
                            </span>
                        </div>

                        <!-- Live + final summary stats: Imported / Skipped(dup) / Skipped(unresolved) -->
                        <div invisible="state == 'draft'"
                             class="o_form_statusbar"
                             style="display: flex; gap: 12px; margin: 8px 0;">
                            <div style="flex:1; padding:10px; border-radius:6px; background:#dcfce7; border:1px solid #86efac;">
                                <div style="font-size:11px; color:#15803d; font-weight:600;">IMPORTED</div>
                                <field name="imported_count" readonly="1"
                                       nolabel="1"
                                       style="font-size:22px; font-weight:700; color:#166534;"/>
                            </div>
                            <div style="flex:1; padding:10px; border-radius:6px; background:#fef3c7; border:1px solid #fde047;">
                                <div style="font-size:11px; color:#a16207; font-weight:600;">DUPLICATES SKIPPED</div>
                                <field name="duplicate_count" readonly="1"
                                       nolabel="1"
                                       style="font-size:22px; font-weight:700; color:#854d0e;"/>
                            </div>
                            <div style="flex:1; padding:10px; border-radius:6px; background:#fee2e2; border:1px solid #fecaca;">
                                <div style="font-size:11px; color:#b91c1c; font-weight:600;">UNRESOLVED SKIPPED</div>
                                <field name="unresolved_count" readonly="1"
                                       nolabel="1"
                                       style="font-size:22px; font-weight:700; color:#991b1b;"/>
                            </div>
                        </div>

                        <!-- Detailed duplicate list (only when there ARE duplicates) -->
                        <group invisible="state != 'done' or duplicate_count == 0"
                               string="Skipped Duplicates — Detail">
                            <field name="duplicate_summary" nolabel="1"
                                   readonly="1" widget="text"
                                   style="font-family: monospace; font-size: 12px;"/>
                        </group>

                        <group invisible="state != 'done'" string="Full Log">
                            <field name="log" nolabel="1" readonly="1" widget="text"/>
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_import"
                                type="object"
                                string="Import"
                                class="oe_highlight"
                                invisible="state == 'done'"/>
                        <button name="action_open_orders"
                                type="object"
                                string="Open Imported Orders"
                                class="oe_highlight"
                                invisible="state != 'done' or imported_count == 0"/>
                        <button name="action_open_duplicates"
                                type="object"
                                string="View Duplicates"
                                class="btn-warning"
                                invisible="state != 'done' or duplicate_count == 0"/>
                        <button string="Close"
                                special="cancel"/>
                    </footer>
                </form>
            </field>
        </record>

        <record id="action_marketplace_import_wizard" model="ir.actions.act_window">
            <field name="name">Import Marketplace Orders</field>
            <field name="res_model">kob.marketplace.import.wizard</field>
            <field name="view_mode">form</field>
            <field name="target">new</field>
        </record>

        <menuitem id="menu_marketplace_import"
                  name="Import Orders"
                  parent="kob_base.menu_kob_marketplace"
                  action="action_marketplace_import_wizard"
                  sequence="10"/>
    </data>
</odoo>
