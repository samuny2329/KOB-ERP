<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sale_order_form_view_kob" model="ir.ui.view">
            <field name="name">sale.order.form.kob</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <field name="order_line" position="attributes">
                    <attribute name="context">{'tree_view_ref': 'sale.view_order_form'}</attribute>
                </field>
                <!-- Order Lines columns matching UAT: Product ID, Barcode,
                     Variant, Delivered, Invoiced, Packaging Q, Packaging,
                     Brand. -->
                <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']" position="before">
                    <field name="product_id"
                           string="Product ID"
                           optional="show" readonly="1"/>
                </xpath>
                <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']" position="after">
                    <field name="x_kob_brand" optional="show"/>
                </xpath>
                <xpath expr="//field[@name='order_line']/list/field[@name='product_uom_qty']" position="before">
                    <field name="qty_delivered"
                           string="Delivered"
                           optional="show" readonly="1"/>
                    <field name="qty_invoiced"
                           string="Invoiced"
                           optional="show" readonly="1"/>
                </xpath>

                <!-- UAT-style top-of-form: 2-column layout matching screenshot.
                     Left column under Customer: Order Type, Sales Team, Warehouse.
                     Right column: Order Date, Pricelist, Payment Terms, Delivery
                     Date, Currency, Source Document, Source. -->
                <xpath expr="//field[@name='partner_id']" position="after">
                    <field name="sale_order_type_id"
                           string="Order Type"
                           options="{'no_create_edit': True}"/>
                    <field name="team_id"
                           string="Sales Team"
                           options="{'no_create_edit': True}"/>
                    <field name="client_order_ref"
                           string="Marketplace Order #"
                           placeholder="Shopee / Lazada / TikTok order_sn"/>
                    <field name="tag_ids" widget="many2many_tags"
                           options="{'color_field': 'color'}"/>
                </xpath>

                <!-- Right column extras — date_order is always there;
                     append delivery date + source. -->
                <xpath expr="//field[@name='date_order']" position="after">
                    <field name="commitment_date"
                           string="Delivery Date"/>
                    <field name="source_id"
                           string="Source"
                           options="{'no_create_edit': True}"/>
                </xpath>

                <!-- Approvals tab — mirrors UAT.  Empty until a workflow
                     hooks rules in (left as a placeholder so the tab
                     order matches the screenshot). -->
                <xpath expr="//notebook" position="inside">
                    <page string="Approvals" name="kob_approvals">
                        <group>
                            <group string="Approval Status">
                                <field name="state" readonly="1"/>
                                <field name="user_id" readonly="1"
                                       string="Sales Person"/>
                                <field name="team_id" readonly="1"
                                       string="Sales Team"/>
                            </group>
                            <group string="Locked / Confirmed">
                                <field name="locked"
                                       readonly="1"/>
                                <field name="date_order"
                                       readonly="1"
                                       string="Confirmed at"
                                       invisible="state not in ['sale','done']"/>
                            </group>
                        </group>
                    </page>
                    <page string="KOB Marketplace" name="kob_marketplace">
                        <group>
                            <group string="Identity">
                                <field name="client_order_ref"
                                       readonly="1"
                                       string="Original order #"/>
                                <field name="source_id" readonly="1"
                                       string="Source / Shop"/>
                                <field name="campaign_id" readonly="1"
                                       string="Campaign"/>
                                <field name="medium_id" readonly="1"
                                       string="Medium"/>
                            </group>
                            <group string="Routing">
                                <field name="warehouse_id" readonly="1"/>
                                <field name="company_id" readonly="1"
                                       groups="base.group_multi_company"/>
                                <field name="user_id" readonly="1"/>
                                <field name="team_id" readonly="1"
                                       options="{'no_create_edit': True}"/>
                            </group>
                        </group>
                        <separator string="Brand &amp; Lines"/>
                        <field name="order_line" readonly="1" nolabel="1">
                            <list>
                                <field name="x_kob_brand" string="Brand"/>
                                <field name="product_id"/>
                                <field name="product_uom_qty"
                                       string="Qty"/>
                                <field name="price_unit"/>
                                <field name="price_subtotal"
                                       string="Subtotal"/>
                            </list>
                        </field>
                        <separator string="Linked Pickings"/>
                        <field name="picking_ids" readonly="1" nolabel="1">
                            <list>
                                <field name="name"/>
                                <field name="state"/>
                                <field name="scheduled_date"/>
                                <field name="x_kob_products_availability"
                                       string="Availability"/>
                                <field name="x_kob_fake_order"
                                       string="Fake?"/>
                            </list>
                        </field>
                    </page>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
