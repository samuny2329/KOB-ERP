<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="sale_order_form_view_kob" model="ir.ui.view">
            <field name="name">sale.order.form.kob</field>
            <field name="model">sale.order</field>
            <field name="inherit_id" ref="sale.view_order_form"/>
            <field name="arch" type="xml">
                <field name="order_line" position="attributes">
                    <attribute name="context">{'tree_view_ref': 'sale.view_order_form'}</attribute>
                </field>
                <xpath expr="//field[@name='order_line']/list/field[@name='product_template_id']" position="after">
                    <field name="x_kob_brand" optional="show"/>
                </xpath>
            </field>
        </record>
    </data>
</odoo>
