<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <record id="product_template_form_view_kob" model="ir.ui.view">
            <field name="name">product.template.form.kob</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_form_view"/>
            <field name="arch" type="xml">
                <xpath expr="//page[@name='general_information']" position="inside">
                    <group>
                        <group string="KOB Marketplace">
                            <field name="x_kob_brand"
                                   placeholder="e.g. KISS-MY-BODY, SKINOXY"/>
                            <field name="x_kob_sku_code"
                                   placeholder="e.g. KHKB038, DUT300"/>
                        </group>
                        <group string="Thai Compliance">
                            <field name="x_kob_wht_tax_id"
                                   options="{'no_create': True}"/>
                            <field name="x_kob_start_selling_date"/>
                        </group>
                    </group>
                    <separator string="Variant Sales Description"/>
                    <field name="x_kob_variant_sales_description"
                           nolabel="1"
                           placeholder="e.g. Smooth chocolate notes, low acidity"/>
                    <separator string="Internal Notes"/>
                    <field name="x_kob_internal_note" nolabel="1"
                           placeholder="Notes only visible to staff"/>
                </xpath>
            </field>
        </record>

        <record id="product_template_search_view_kob" model="ir.ui.view">
            <field name="name">product.template.search.kob</field>
            <field name="model">product.template</field>
            <field name="inherit_id" ref="product.product_template_search_view"/>
            <field name="arch" type="xml">
                <field name="name" position="after">
                    <field name="x_kob_sku_code" string="KOB SKU"/>
                    <field name="x_kob_brand" string="KOB Brand"/>
                </field>
            </field>
        </record>
    </data>
</odoo>
