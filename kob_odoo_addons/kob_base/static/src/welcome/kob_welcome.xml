<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- KOB ERP — Welcome
         Odoo 19 enterprise-style home menu: diagonal stripe background,
         plain centered app grid, draggable tiles. No toolbar, no chips. -->

    <t t-name="kob_base.Welcome">
        <div class="kob-welcome o_action_manager">

            <div class="kob-grid-wrap">
                <div class="kob-grid">
                    <t t-foreach="filteredModules" t-as="mod" t-key="mod.key">
                        <button type="button"
                                class="kob-app"
                                draggable="true"
                                t-att-data-key="mod.key"
                                t-att-title="mod.description"
                                t-att-class="{
                                    'kob-app--dragging': state.draggingKey === mod.key,
                                    'kob-app--dragover': state.dragOverKey === mod.key and state.draggingKey !== mod.key,
                                }"
                                t-on-click="() => this.onCardClick(mod)"
                                t-on-dragstart="(ev) => this.onDragStart(ev, mod.key)"
                                t-on-dragover="(ev) => this.onDragOver(ev, mod.key)"
                                t-on-dragleave="(ev) => this.onDragLeave(ev, mod.key)"
                                t-on-drop="(ev) => this.onDrop(ev, mod.key)"
                                t-on-dragend="() => this.onDragEnd()">
                            <div class="kob-app-icon">
                                <span class="kob-app-glyph"
                                      t-attf-style="--kob-app-color: {{mod.color}}; background: {{mod.color}};">
                                    <t t-esc="mod.glyph"/>
                                </span>
                            </div>
                            <h3 class="kob-app-title">
                                <t t-esc="mod.name"/>
                            </h3>
                        </button>
                    </t>
                </div>
            </div>

        </div>
    </t>

</templates>
