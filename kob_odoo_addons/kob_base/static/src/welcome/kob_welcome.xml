<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- ─────────────────────────────────────────────────────────────────
         KOB ERP — Welcome dashboard

         Style cues taken from Odoo 19's "New Page" templates: a tall
         gradient hero with strong typography, a "Featured" row of two
         oversized cards on a coloured panel, then a clean tile grid by
         category, and a subtle footer.
         ──────────────────────────────────────────────────────────────── -->

    <t t-name="kob_base.Welcome">
        <div class="kob-welcome o_action_manager">

            <!-- ── HERO ─────────────────────────────────────────────── -->
            <section class="kob-hero">
                <div class="kob-hero-grid"/>
                <div class="kob-container kob-hero-inner">
                    <div class="kob-hero-eyebrow">KISS OF BEAUTY · ENTERPRISE ERP</div>
                    <h1 class="kob-hero-title">
                        Welcome to <span class="kob-hero-accent">KOB ERP</span>
                    </h1>
                    <p class="kob-hero-sub">
                        ระบบ ERP รวมศูนย์สำหรับธุรกิจกลุ่ม Kiss of Beauty —
                        คลังสินค้า, ขาย, ซื้อ, ผลิต, บัญชี, HR และ Thai compliance
                        ทั้งหมดในที่เดียว.
                        <br/>
                        <span class="opacity-75">Pick a module below to get started.</span>
                    </p>
                    <div class="kob-hero-search">
                        <i class="oi oi-search kob-hero-search-icon"/>
                        <input type="search"
                               class="kob-hero-search-input"
                               placeholder="ค้นหาโหมด · Search modules (e.g. Sales, SSO, OEE)"
                               t-on-input="onSearchInput"
                               t-att-value="state.search"/>
                    </div>
                    <div class="kob-hero-chips">
                        <button type="button"
                                class="kob-chip"
                                t-att-class="{ 'kob-chip--active': !state.category }"
                                t-on-click="() => this.onCategoryClick(null)">
                            All / ทั้งหมด
                        </button>
                        <t t-foreach="categories" t-as="c" t-key="c.id">
                            <button type="button"
                                    class="kob-chip"
                                    t-att-class="{ 'kob-chip--active': state.category === c.id }"
                                    t-on-click="() => this.onCategoryClick(c.id)">
                                <span class="kob-chip-dot" t-attf-style="background: {{c.color}};"/>
                                <t t-esc="c.label"/>
                            </button>
                        </t>
                    </div>
                </div>
            </section>

            <!-- ── FEATURED (top KOB ERP-only highlights) ───────────── -->
            <section class="kob-featured" t-if="!state.category and !state.search">
                <div class="kob-container">
                    <div class="kob-section-head">
                        <span class="kob-section-rule"/>
                        <span class="kob-section-label">FEATURED · ฟีเจอร์เด่น</span>
                        <span class="kob-section-rule kob-section-rule-r"/>
                    </div>
                    <div class="kob-featured-grid">
                        <button type="button"
                                class="kob-featured-card kob-featured-card--lg"
                                t-on-click="() => this.onCardClick(modules.find(m => m.key === 'kob_thai_compliance'))">
                            <div class="kob-featured-icon" style="background: #107e3e;">ภ</div>
                            <div class="kob-featured-body">
                                <div class="kob-featured-eyebrow">ความเฉพาะของ KOB ERP</div>
                                <h3 class="kob-featured-title">Thailand Compliance</h3>
                                <p class="kob-featured-desc">
                                    SSO 5%+5% (capped 750฿) · PND withholding tax brackets ·
                                    Thai LPA overtime (1.5×/3×) · annual leave entitlement ·
                                    fixed-asset depreciation · period-end FX revaluation —
                                    ครบทุก compliance ที่ SME ไทยต้องการ.
                                </p>
                                <span class="kob-featured-cta">เปิดโหมด <span aria-hidden="true">→</span></span>
                            </div>
                        </button>
                        <button type="button"
                                class="kob-featured-card kob-featured-card--lg"
                                t-on-click="() => this.onCardClick(modules.find(m => m.key === 'kob_wh_online'))">
                            <div class="kob-featured-icon" style="background: #354a5f;">W</div>
                            <div class="kob-featured-body">
                                <div class="kob-featured-eyebrow">CORE OPERATION</div>
                                <h3 class="kob-featured-title">WH-Online E-Commerce</h3>
                                <p class="kob-featured-desc">
                                    Pick · Pack · Outbound · Dispatch fullscreen scan-driven
                                    workflow ที่เชื่อม Shopee · Lazada · TikTok · POS เข้ากับ
                                    Odoo stock — ตัด stock อัตโนมัติเมื่อ pack เสร็จ.
                                </p>
                                <span class="kob-featured-cta">เปิดโหมด <span aria-hidden="true">→</span></span>
                            </div>
                        </button>
                    </div>
                </div>
            </section>

            <!-- ── ALL MODULES BY CATEGORY ──────────────────────────── -->
            <section class="kob-modules">
                <div class="kob-container">
                    <t t-foreach="grouped()" t-as="cat" t-key="cat.id">
                        <div class="kob-cat">
                            <div class="kob-section-head">
                                <span class="kob-section-rule"/>
                                <span class="kob-section-label">
                                    <span class="kob-section-dot" t-attf-style="background: {{cat.color}};"/>
                                    <t t-esc="cat.label"/>
                                </span>
                                <span class="kob-section-rule kob-section-rule-r"/>
                                <span class="kob-section-count">
                                    <t t-esc="cat.modules.length"/>
                                </span>
                            </div>
                            <div class="kob-cards">
                                <t t-foreach="cat.modules" t-as="mod" t-key="mod.key">
                                    <button type="button"
                                            class="kob-card"
                                            t-on-click="() => this.onCardClick(mod)">
                                        <div class="kob-card-icon" t-attf-style="background: {{mod.color}};">
                                            <t t-esc="mod.glyph"/>
                                        </div>
                                        <h3 class="kob-card-title">
                                            <t t-esc="mod.name"/>
                                        </h3>
                                        <p class="kob-card-desc">
                                            <t t-esc="mod.description"/>
                                        </p>
                                        <span class="kob-card-cta">เปิด <span aria-hidden="true">→</span></span>
                                    </button>
                                </t>
                            </div>
                        </div>
                    </t>

                    <t t-if="filteredModules.length === 0">
                        <div class="kob-empty">
                            <div class="kob-empty-icon">🔍</div>
                            <p class="kob-empty-text">ไม่พบโหมดที่ค้นหา · No modules match your filter</p>
                        </div>
                    </t>
                </div>
            </section>

            <!-- ── FOOTER ───────────────────────────────────────────── -->
            <footer class="kob-foot">
                <div class="kob-container kob-foot-inner">
                    <div class="kob-foot-brand">
                        <span class="kob-foot-mark">K</span>
                        <span>KOB ERP · Kiss of Beauty Co., Ltd.</span>
                    </div>
                    <div class="kob-foot-meta">
                        Powered by Odoo 19 · KOB custom addons · SAP Fiori-style theme
                    </div>
                </div>
            </footer>

        </div>
    </t>

</templates>
