<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">

    <!-- KOB ERP — Welcome dashboard
         Style: Odoo native — single wide grid of large white app tiles,
         drag-and-drop reorderable, persisted in localStorage. -->

    <t t-name="kob_base.Welcome">
        <div class="kob-welcome o_action_manager">

            <!-- ── HEADER (search + filter + reset) ───────────────── -->
            <section class="kob-hero">
                <div class="kob-container">
                    <div class="kob-hero-row">
                        <div>
                            <h1 class="kob-hero-title">KOB ERP</h1>
                            <p class="kob-hero-sub">Drag tiles to rearrange · click to open</p>
                        </div>
                        <div class="kob-hero-actions">
                            <div class="kob-hero-search">
                                <i class="fa fa-search kob-hero-search-icon" aria-hidden="true"/>
                                <input type="search"
                                       class="kob-hero-search-input form-control"
                                       placeholder="Search apps..."
                                       t-on-input="onSearchInput"
                                       t-att-value="state.search"/>
                            </div>
                            <button type="button"
                                    class="kob-reset-btn"
                                    title="Reset order"
                                    t-on-click="() => this.resetOrder()">
                                <i class="fa fa-undo" aria-hidden="true"/> Reset
                            </button>
                        </div>
                    </div>

                    <div class="kob-hero-chips">
                        <button type="button"
                                class="kob-chip"
                                t-att-class="{ 'kob-chip--active': !state.category }"
                                t-on-click="() => this.onCategoryClick(null)">
                            All
                        </button>
                        <t t-foreach="categories" t-as="c" t-key="c.id">
                            <button type="button"
                                    class="kob-chip"
                                    t-att-class="{ 'kob-chip--active': state.category === c.id }"
                                    t-on-click="() => this.onCategoryClick(c.id)">
                                <t t-esc="c.label"/>
                            </button>
                        </t>
                    </div>
                </div>
            </section>

            <!-- ── APP GRID (single grid, draggable) ──────────────── -->
            <section class="kob-modules">
                <div class="kob-container">
                    <div class="kob-cards">
                        <t t-foreach="filteredModules" t-as="mod" t-key="mod.key">
                            <button type="button"
                                    class="kob-card"
                                    draggable="true"
                                    t-att-data-key="mod.key"
                                    t-att-title="mod.description"
                                    t-att-class="{
                                        'kob-card--dragging': state.draggingKey === mod.key,
                                        'kob-card--dragover': state.dragOverKey === mod.key and state.draggingKey !== mod.key,
                                    }"
                                    t-on-click="() => this.onCardClick(mod)"
                                    t-on-dragstart="(ev) => this.onDragStart(ev, mod.key)"
                                    t-on-dragover="(ev) => this.onDragOver(ev, mod.key)"
                                    t-on-dragleave="(ev) => this.onDragLeave(ev, mod.key)"
                                    t-on-drop="(ev) => this.onDrop(ev, mod.key)"
                                    t-on-dragend="() => this.onDragEnd()">
                                <div class="kob-card-icon"
                                     t-attf-style="background: {{mod.color}};">
                                    <span class="kob-card-glyph">
                                        <t t-esc="mod.glyph"/>
                                    </span>
                                </div>
                                <h3 class="kob-card-title">
                                    <t t-esc="mod.name"/>
                                </h3>
                            </button>
                        </t>
                    </div>

                    <t t-if="filteredModules.length === 0">
                        <div class="kob-empty">
                            <i class="fa fa-search-minus kob-empty-icon" aria-hidden="true"/>
                            <p class="kob-empty-text">No apps match your search</p>
                        </div>
                    </t>
                </div>
            </section>

            <!-- ── FOOTER ─────────────────────────────────────────── -->
            <footer class="kob-foot">
                <div class="kob-container kob-foot-inner">
                    <span class="kob-foot-brand">
                        KOB ERP · Kiss of Beauty Co., Ltd.
                    </span>
                    <span class="kob-foot-version">
                        Powered by Odoo 19
                    </span>
                </div>
            </footer>

        </div>
    </t>

</templates>
