<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kob_cash_pool_list" model="ir.ui.view">
        <field name="name">kob.cash.pool.list</field>
        <field name="model">kob.cash.pool</field>
        <field name="arch" type="xml">
            <list string="Cash Pools">
                <field name="name"/>
                <field name="parent_company_id"/>
                <field name="target_balance"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_kob_cash_pool_form" model="ir.ui.view">
        <field name="name">kob.cash.pool.form</field>
        <field name="model">kob.cash.pool</field>
        <field name="arch" type="xml">
            <form string="Cash Pool">
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="parent_company_id"/>
                        </group>
                        <group>
                            <field name="target_balance"/>
                            <field name="currency_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Members">
                            <field name="member_ids">
                                <list editable="bottom">
                                    <field name="company_id"/>
                                    <field name="bank_journal_id"/>
                                    <field name="weight"/>
                                </list>
                            </field>
                        </page>
                        <page string="Forecasts">
                            <field name="forecast_ids">
                                <list>
                                    <field name="forecast_date"/>
                                    <field name="opening_balance"/>
                                    <field name="cash_in"/>
                                    <field name="cash_out"/>
                                    <field name="projected_balance"/>
                                    <field name="risk_flag"
                                           decoration-success="risk_flag == 'ok'"
                                           decoration-warning="risk_flag == 'low'"
                                           decoration-danger="risk_flag == 'critical'"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes"><field name="note"/></page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_kob_cash_pool" model="ir.actions.act_window">
        <field name="name">Cash Pools</field>
        <field name="res_model">kob.cash.pool</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem
        id="menu_kob_cash_pool"
        name="Cash Pools"
        parent="menu_kob_group_root"
        action="action_kob_cash_pool"
        sequence="50"/>
</odoo>
