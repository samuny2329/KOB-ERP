<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kob_inventory_pool_list" model="ir.ui.view">
        <field name="name">kob.inventory.pool.list</field>
        <field name="model">kob.inventory.pool</field>
        <field name="arch" type="xml">
            <list string="Inventory Pools">
                <field name="code"/>
                <field name="name"/>
                <field name="parent_company_id"/>
                <field name="active"/>
            </list>
        </field>
    </record>
    <record id="view_kob_inventory_pool_form" model="ir.ui.view">
        <field name="name">kob.inventory.pool.form</field>
        <field name="model">kob.inventory.pool</field>
        <field name="arch" type="xml">
            <form string="Inventory Pool">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="parent_company_id"/>
                        <field name="active"/>
                    </group>
                    <notebook>
                        <page string="Members">
                            <field name="member_ids">
                                <list editable="bottom">
                                    <field name="company_id"/>
                                    <field name="warehouse_id"/>
                                    <field name="priority"/>
                                    <field name="transfer_cost_per_km"/>
                                </list>
                            </field>
                        </page>
                        <page string="Routing Rules">
                            <field name="rule_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="product_category_id"/>
                                    <field name="strategy"/>
                                    <field name="min_qty_threshold"/>
                                    <field name="active"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes"><field name="note"/></page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_kob_inventory_pool" model="ir.actions.act_window">
        <field name="name">Inventory Pools</field>
        <field name="res_model">kob.inventory.pool</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem
        id="menu_kob_inventory_pool"
        name="Inventory Pools"
        parent="menu_kob_group_root"
        action="action_kob_inventory_pool"
        sequence="10"/>
</odoo>
