<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kob_intercompany_transfer_list" model="ir.ui.view">
        <field name="name">kob.intercompany.transfer.list</field>
        <field name="model">kob.intercompany.transfer</field>
        <field name="arch" type="xml">
            <list string="Intercompany Transfers">
                <field name="create_date"/>
                <field name="sales_order_id"/>
                <field name="so_company_id"/>
                <field name="fulfillment_company_id"/>
                <field name="state"
                       decoration-info="state == 'draft'"
                       decoration-warning="state == 'mirrored'"
                       decoration-success="state == 'settled'"
                       decoration-muted="state == 'cancelled'"/>
                <field name="transfer_pricing_method"/>
                <field name="transfer_pricing_pct"/>
                <field name="transfer_amount" sum="Total"/>
                <field name="mirror_po_id"/>
                <field name="settled_at"/>
                <field name="currency_id" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_kob_intercompany_transfer_form" model="ir.ui.view">
        <field name="name">kob.intercompany.transfer.form</field>
        <field name="model">kob.intercompany.transfer</field>
        <field name="arch" type="xml">
            <form string="Intercompany Transfer">
                <header>
                    <button name="action_mirror" type="object"
                            string="Create Mirror PO" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_settle" type="object"
                            string="Settle"
                            invisible="state != 'mirrored'"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state in ('settled','cancelled')"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,mirrored,settled"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="sales_order_id"/>
                            <field name="so_company_id"/>
                            <field name="fulfillment_company_id"/>
                            <field name="mirror_po_id" readonly="1"/>
                            <field name="settled_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="transfer_pricing_method"/>
                            <field name="transfer_pricing_pct"/>
                            <field name="transfer_amount"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes"><field name="note"/></page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kob_intercompany_transfer" model="ir.actions.act_window">
        <field name="name">Intercompany Transfers</field>
        <field name="res_model">kob.intercompany.transfer</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_kob_intercompany_transfer"
        name="Intercompany Transfers"
        parent="menu_kob_sales_pro_root"
        action="action_kob_intercompany_transfer"
        sequence="50"/>
</odoo>
