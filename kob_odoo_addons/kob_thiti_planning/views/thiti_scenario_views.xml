<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_thiti_scenario_list" model="ir.ui.view">
        <field name="name">thiti.scenario.list</field>
        <field name="model">thiti.scenario</field>
        <field name="arch" type="xml">
            <list string="Scenarios">
                <field name="name"/>
                <field name="is_baseline" widget="boolean_toggle"/>
                <field name="parent_id"/>
                <field name="capacity_factor"/>
                <field name="demand_factor"/>
                <field name="leadtime_factor"/>
                <field name="run_count"/>
                <field name="active" widget="boolean_toggle" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_thiti_scenario_form" model="ir.ui.view">
        <field name="name">thiti.scenario.form</field>
        <field name="model">thiti.scenario</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_clone" type="object"
                            string="Clone Scenario" class="btn-secondary"/>
                    <button name="action_run_plan" type="object"
                            string="Run Plan" class="btn-primary"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="is_baseline"/>
                            <field name="parent_id"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="capacity_factor"/>
                            <field name="demand_factor"/>
                            <field name="leadtime_factor"/>
                            <field name="run_count" readonly="1"/>
                        </group>
                    </group>
                    <group><field name="description" nolabel="1"/></group>
                    <notebook>
                        <page string="Plan Runs">
                            <field name="plan_run_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="state"/>
                                    <field name="create_date"/>
                                    <field name="duration_seconds"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_thiti_scenario" model="ir.actions.act_window">
        <field name="name">Scenarios</field>
        <field name="res_model">thiti.scenario</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_thiti_scenario_compare_form" model="ir.ui.view">
        <field name="name">thiti.scenario.compare.form</field>
        <field name="model">thiti.scenario.compare</field>
        <field name="arch" type="xml">
            <form string="Scenario Comparison">
                <group>
                    <group string="Scenario A">
                        <field name="scenario_left_id"/>
                        <field name="run_left_id"/>
                    </group>
                    <group string="Scenario B">
                        <field name="scenario_right_id"/>
                        <field name="run_right_id"/>
                    </group>
                </group>
                <group string="Results" col="4">
                    <field name="sl_left"/><field name="sl_right"/>
                    <field name="util_left"/><field name="util_right"/>
                    <field name="cost_left"/><field name="cost_right"/>
                    <field name="delay_left"/><field name="delay_right"/>
                    <field name="currency_id" invisible="1"/>
                </group>
                <footer>
                    <button name="action_compare" type="object"
                            string="Compare" class="btn-primary"/>
                    <button special="cancel" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_thiti_scenario_compare" model="ir.actions.act_window">
        <field name="name">Compare Scenarios</field>
        <field name="res_model">thiti.scenario.compare</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
