<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_thiti_forecast_override_list" model="ir.ui.view">
        <field name="name">thiti.forecast.override.list</field>
        <field name="model">thiti.forecast.override</field>
        <field name="arch" type="xml">
            <list string="Forecast Overrides" create="false">
                <field name="forecast_id"/>
                <field name="item_id"/>
                <field name="location_id"/>
                <field name="bucket_start"/>
                <field name="previous_qty"/>
                <field name="new_qty"/>
                <field name="delta_qty"
                       decoration-success="delta_qty &gt; 0"
                       decoration-danger="delta_qty &lt; 0"/>
                <field name="reason" widget="badge"/>
                <field name="user_id"/>
                <field name="write_date"/>
            </list>
        </field>
    </record>

    <record id="view_thiti_forecast_override_form" model="ir.ui.view">
        <field name="name">thiti.forecast.override.form</field>
        <field name="model">thiti.forecast.override</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="forecast_id"/>
                            <field name="item_id" readonly="1"/>
                            <field name="location_id" readonly="1"/>
                            <field name="bucket_start" readonly="1"/>
                            <field name="bucket_end" readonly="1"/>
                        </group>
                        <group>
                            <field name="previous_qty" readonly="1"/>
                            <field name="new_qty"/>
                            <field name="delta_qty" readonly="1"/>
                            <field name="reason"/>
                            <field name="user_id" readonly="1"/>
                        </group>
                    </group>
                    <group>
                        <field name="comment" nolabel="1" placeholder="Reason narrative..."/>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_thiti_forecast_override" model="ir.actions.act_window">
        <field name="name">Forecast Overrides</field>
        <field name="res_model">thiti.forecast.override</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
