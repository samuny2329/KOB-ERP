<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_thiti_plan_run_list" model="ir.ui.view">
        <field name="name">thiti.plan.run.list</field>
        <field name="model">thiti.plan.run</field>
        <field name="arch" type="xml">
            <list string="Plan Runs" sample="1">
                <field name="name"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'done'"
                       decoration-info="state == 'draft'"
                       decoration-warning="state in ('collecting','solving','parsing')"
                       decoration-danger="state in ('failed','canceled')"/>
                <field name="plan_type"/>
                <field name="constraint_level"/>
                <field name="plan_horizon_days"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <field name="item_count" optional="show"/>
                <field name="demand_count" optional="show"/>
                <field name="duration_seconds" optional="show"/>
                <field name="create_date" optional="show"/>
                <field name="user_id" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_thiti_plan_run_form" model="ir.ui.view">
        <field name="name">thiti.plan.run.form</field>
        <field name="model">thiti.plan.run</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_collect_preview"
                            type="object"
                            string="Collect &amp; Preview"
                            class="btn-primary"
                            invisible="state in ('collecting','solving','parsing','done')"/>
                    <button name="action_run"
                            type="object"
                            string="Run Plan"
                            class="btn-success"
                            invisible="state in ('collecting','solving','parsing','done')"
                            help="Phase 4: collects XML only. Solver wired in Phase 5."/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,collecting,solving,parsing,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="plan_type"/>
                            <field name="constraint_level"/>
                            <field name="plan_horizon_days"/>
                            <field name="plan_currentdate"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="warehouse_ids" widget="many2many_tags"/>
                        </group>
                        <group>
                            <field name="user_id" readonly="1"/>
                            <field name="started_at" readonly="1"/>
                            <field name="finished_at" readonly="1"/>
                            <field name="duration_seconds" readonly="1"/>
                            <field name="input_xml_attachment_id" readonly="1"/>
                            <field name="output_xml_attachment_id" readonly="1"/>
                        </group>
                    </group>
                    <group string="Counts" col="4">
                        <field name="item_count" readonly="1"/>
                        <field name="location_count" readonly="1"/>
                        <field name="buffer_count" readonly="1"/>
                        <field name="operation_count" readonly="1"/>
                        <field name="resource_count" readonly="1"/>
                        <field name="demand_count" readonly="1"/>
                        <field name="supplier_count" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Log">
                            <field name="log" nolabel="1" readonly="1"/>
                        </page>
                        <page string="Error" invisible="not error_message">
                            <field name="error_message" nolabel="1" readonly="1"/>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_thiti_plan_run" model="ir.actions.act_window">
        <field name="name">Plan Runs</field>
        <field name="res_model">thiti.plan.run</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
