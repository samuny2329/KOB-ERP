<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_thiti_operation_list" model="ir.ui.view">
        <field name="name">thiti.operation.list</field>
        <field name="model">thiti.operation</field>
        <field name="arch" type="xml">
            <list string="Operations">
                <field name="name"/>
                <field name="operation_type"/>
                <field name="bom_id"/>
                <field name="item_id"/>
                <field name="location_id"/>
                <field name="priority"/>
                <field name="active" widget="boolean_toggle" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_thiti_operation_form" model="ir.ui.view">
        <field name="name">thiti.operation.form</field>
        <field name="model">thiti.operation</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title"><label for="name"/><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="operation_type"/>
                            <field name="bom_id"/>
                            <field name="item_id"/>
                            <field name="location_id"/>
                            <field name="priority"/>
                            <field name="search_mode"/>
                        </group>
                        <group>
                            <field name="duration_hours"/>
                            <field name="duration_per_hours"/>
                            <field name="pretime_hours"/>
                            <field name="posttime_hours"/>
                            <field name="cost"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <group string="Size">
                        <group>
                            <field name="sizeminimum"/>
                            <field name="sizemultiple"/>
                            <field name="sizemaximum"/>
                        </group>
                        <group>
                            <field name="effective_start"/>
                            <field name="effective_end"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Flows (Materials)">
                            <field name="flow_ids">
                                <list editable="bottom">
                                    <field name="item_id"/>
                                    <field name="location_id"/>
                                    <field name="flow_type"/>
                                    <field name="quantity"/>
                                    <field name="quantity_fixed"/>
                                    <field name="priority"/>
                                </list>
                            </field>
                        </page>
                        <page string="Loads (Resources)">
                            <field name="load_ids">
                                <list editable="bottom">
                                    <field name="resource_id"/>
                                    <field name="quantity"/>
                                    <field name="skill_id"/>
                                    <field name="priority"/>
                                </list>
                            </field>
                        </page>
                        <page string="Steps">
                            <field name="step_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="priority"/>
                                    <field name="duration_hours"/>
                                    <field name="duration_per_hours"/>
                                    <field name="resource_id"/>
                                    <field name="routing_workcenter_id"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes"><field name="note" nolabel="1"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_thiti_operation" model="ir.actions.act_window">
        <field name="name">Operations</field>
        <field name="res_model">thiti.operation</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
