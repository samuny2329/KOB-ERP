<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_thiti_forecast_list" model="ir.ui.view">
        <field name="name">thiti.forecast.list</field>
        <field name="model">thiti.forecast</field>
        <field name="arch" type="xml">
            <list string="Forecast" sample="1" editable="bottom">
                <field name="item_id"/>
                <field name="location_id"/>
                <field name="customer_id" optional="show"/>
                <field name="bucket_label"/>
                <field name="bucket_start"/>
                <field name="bucket_end" optional="hide"/>
                <field name="forecast_method"/>
                <field name="history_qty" optional="show"/>
                <field name="baseline_qty"/>
                <field name="override_qty"/>
                <field name="consumed_qty" optional="show"/>
                <field name="net_qty"/>
                <field name="total_qty" optional="show"/>
                <field name="bias" optional="hide"/>
                <field name="mape" optional="hide"/>
                <field name="demand_pattern" widget="badge" optional="show"
                       decoration-success="demand_pattern == 'smooth'"
                       decoration-warning="demand_pattern == 'erratic'"
                       decoration-info="demand_pattern == 'intermittent'"
                       decoration-danger="demand_pattern == 'lumpy'"/>
            </list>
        </field>
    </record>

    <record id="view_thiti_forecast_search" model="ir.ui.view">
        <field name="name">thiti.forecast.search</field>
        <field name="model">thiti.forecast</field>
        <field name="arch" type="xml">
            <search>
                <field name="item_id"/>
                <field name="location_id"/>
                <field name="customer_id"/>
                <field name="bucket_label"/>
                <separator/>
                <filter name="has_override" string="Has Override"
                        domain="[('override_qty','&gt;=',0)]"/>
                <filter name="pattern_lumpy" string="Lumpy"
                        domain="[('demand_pattern','=','lumpy')]"/>
                <filter name="pattern_intermittent" string="Intermittent"
                        domain="[('demand_pattern','=','intermittent')]"/>
                <group>
                    <filter name="gb_item" string="Item" context="{'group_by':'item_id'}"/>
                    <filter name="gb_location" string="Location" context="{'group_by':'location_id'}"/>
                    <filter name="gb_method" string="Method" context="{'group_by':'forecast_method'}"/>
                    <filter name="gb_pattern" string="Pattern" context="{'group_by':'demand_pattern'}"/>
                    <filter name="gb_bucket" string="Bucket Month" context="{'group_by':'bucket_start:month'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="view_thiti_forecast_form" model="ir.ui.view">
        <field name="name">thiti.forecast.form</field>
        <field name="model">thiti.forecast</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="display_name"/>
                        <h1><field name="display_name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="item_id"/>
                            <field name="location_id"/>
                            <field name="customer_id"/>
                            <field name="bucket_label"/>
                            <field name="bucket_start"/>
                            <field name="bucket_end"/>
                        </group>
                        <group>
                            <field name="forecast_method"/>
                            <field name="demand_pattern" readonly="1"/>
                            <field name="history_qty"/>
                            <field name="baseline_qty"/>
                            <field name="override_qty"/>
                            <field name="consumed_qty"/>
                            <field name="net_qty" readonly="1"/>
                            <field name="total_qty" readonly="1"/>
                        </group>
                    </group>
                    <group string="Accuracy" col="4">
                        <field name="bias" readonly="1"/>
                        <field name="mape" readonly="1"/>
                        <field name="smape" readonly="1"/>
                        <field name="rmse" readonly="1"/>
                    </group>
                    <notebook>
                        <page string="Notes"><field name="note" nolabel="1"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_thiti_forecast_pivot" model="ir.ui.view">
        <field name="name">thiti.forecast.pivot</field>
        <field name="model">thiti.forecast</field>
        <field name="arch" type="xml">
            <pivot string="Forecast Analysis" sample="1">
                <field name="item_id" type="row"/>
                <field name="bucket_start" type="col" interval="month"/>
                <field name="baseline_qty" type="measure"/>
                <field name="net_qty" type="measure"/>
                <field name="consumed_qty" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_thiti_forecast_graph" model="ir.ui.view">
        <field name="name">thiti.forecast.graph</field>
        <field name="model">thiti.forecast</field>
        <field name="arch" type="xml">
            <graph string="Forecast Trend" sample="1" type="line" stacked="0">
                <field name="bucket_start" interval="month"/>
                <field name="baseline_qty" type="measure"/>
                <field name="net_qty" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="action_thiti_forecast" model="ir.actions.act_window">
        <field name="name">Forecast</field>
        <field name="res_model">thiti.forecast</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_thiti_forecast_search"/>
    </record>
</odoo>
