<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_thiti_customer_list" model="ir.ui.view">
        <field name="name">thiti.customer.list</field>
        <field name="model">thiti.customer</field>
        <field name="arch" type="xml">
            <list string="Customers">
                <field name="name"/>
                <field name="code"/>
                <field name="partner_id"/>
                <field name="priority"/>
                <field name="active" widget="boolean_toggle" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_thiti_customer_form" model="ir.ui.view">
        <field name="name">thiti.customer.form</field>
        <field name="model">thiti.customer</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title"><label for="name"/><h1><field name="name"/></h1></div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="partner_id"/>
                        </group>
                        <group>
                            <field name="priority"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes"><field name="note" nolabel="1"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_thiti_customer" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">thiti.customer</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
