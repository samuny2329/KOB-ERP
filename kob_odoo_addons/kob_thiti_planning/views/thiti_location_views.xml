<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_thiti_location_list" model="ir.ui.view">
        <field name="name">thiti.location.list</field>
        <field name="model">thiti.location</field>
        <field name="arch" type="xml">
            <list string="Locations">
                <field name="complete_name"/>
                <field name="code"/>
                <field name="warehouse_id"/>
                <field name="calendar_id"/>
                <field name="active" widget="boolean_toggle" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_thiti_location_form" model="ir.ui.view">
        <field name="name">thiti.location.form</field>
        <field name="model">thiti.location</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <widget name="web_ribbon" title="Archived" bg_color="bg-danger" invisible="active"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="code"/>
                            <field name="parent_id"/>
                            <field name="warehouse_id"/>
                            <field name="odoo_location_id"/>
                        </group>
                        <group>
                            <field name="calendar_id"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Children">
                            <field name="child_ids" readonly="1"/>
                        </page>
                        <page string="Notes"><field name="note" nolabel="1"/></page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="action_thiti_location" model="ir.actions.act_window">
        <field name="name">Locations</field>
        <field name="res_model">thiti.location</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
