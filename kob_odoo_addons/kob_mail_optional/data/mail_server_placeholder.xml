        <field name="name">KOB SMTP (configure me)</field>
        <field name="smtp_host">smtp.gmail.com</field>
        <field name="smtp_port">587</field>
        <field name="smtp_encryption">starttls</field>
        <field name="smtp_user">configure-me@kissofbeauty.co.th</field>
        <field name="from_filter">@kissofbeauty.co.th</field>
        <field name="active" eval="False"/>
        <field name="sequence">100</field>
    </record>
</odoo>
