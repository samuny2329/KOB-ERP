<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kob_webhook_config_list" model="ir.ui.view">
        <field name="name">kob.webhook.config.list</field>
        <field name="model">kob.webhook.config</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="model_name"/>
                <field name="trigger"/>
                <field name="target_url"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="view_kob_webhook_config_form" model="ir.ui.view">
        <field name="name">kob.webhook.config.form</field>
        <field name="model">kob.webhook.config</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_test" type="object" string="Test Fire"
                            class="oe_highlight"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="active"/>
                            <field name="model_id"/>
                            <field name="trigger"/>
                            <field name="state_filter" placeholder="[('state','=','done')]"/>
                        </group>
                        <group>
                            <field name="target_url" placeholder="https://example.com/webhook"/>
                            <field name="method"/>
                            <field name="auth_header" placeholder="Bearer abc123"/>
                            <field name="retry_max"/>
                            <field name="timeout_sec"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Payload Template">
                            <field name="payload_template" widget="text"/>
                        </page>
                        <page string="Recent Logs">
                            <field name="log_ids" readonly="1">
                                <list>
                                    <field name="create_date"/>
                                    <field name="trigger"/>
                                    <field name="record_id"/>
                                    <field name="status_code"
                                           decoration-success="status_code == 200"
                                           decoration-danger="status_code &gt;= 400 or status_code == 0"/>
                                    <field name="success"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kob_webhook_config" model="ir.actions.act_window">
        <field name="name">Webhooks</field>
        <field name="res_model">kob.webhook.config</field>
        <field name="view_mode">list,form</field>
    </record>

    <record id="view_kob_webhook_log_list" model="ir.ui.view">
        <field name="name">kob.webhook.log.list</field>
        <field name="model">kob.webhook.log</field>
        <field name="arch" type="xml">
            <list create="0" edit="0" delete="0">
                <field name="create_date"/>
                <field name="config_id"/>
                <field name="model_name"/>
                <field name="record_id"/>
                <field name="trigger"/>
                <field name="status_code"/>
                <field name="success"/>
            </list>
        </field>
    </record>

    <record id="action_kob_webhook_log" model="ir.actions.act_window">
        <field name="name">Webhook Logs</field>
        <field name="res_model">kob.webhook.log</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_kob_webhooks_root" name="Webhooks"
              parent="kob_base.menu_kob_root" sequence="90"/>
    <menuitem id="menu_kob_webhook_config" name="Webhook Configs"
              parent="menu_kob_webhooks_root"
              action="action_kob_webhook_config" sequence="10"/>
    <menuitem id="menu_kob_webhook_log" name="Delivery Logs"
              parent="menu_kob_webhooks_root"
              action="action_kob_webhook_log" sequence="20"/>
</odoo>
