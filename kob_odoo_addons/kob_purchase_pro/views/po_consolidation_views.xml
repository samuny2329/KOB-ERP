<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kob_po_consolidation_list" model="ir.ui.view">
        <field name="name">kob.po.consolidation.proposal.list</field>
        <field name="model">kob.po.consolidation.proposal</field>
        <field name="arch" type="xml">
            <list string="PO Consolidation Proposals">
                <field name="proposed_at"/>
                <field name="vendor_id"/>
                <field name="total_lines"/>
                <field name="original_total" sum="Original"/>
                <field name="estimated_saving" sum="Saving"/>
                <field name="saving_pct"/>
                <field name="status"
                       decoration-info="status == 'pending'"
                       decoration-success="status == 'accepted'"
                       decoration-muted="status == 'rejected'"/>
            </list>
        </field>
    </record>

    <record id="view_kob_po_consolidation_form" model="ir.ui.view">
        <field name="name">kob.po.consolidation.proposal.form</field>
        <field name="model">kob.po.consolidation.proposal</field>
        <field name="arch" type="xml">
            <form string="PO Consolidation">
                <header>
                    <button name="action_accept" type="object"
                            string="Accept" class="oe_highlight"
                            invisible="status != 'pending'"/>
                    <button name="action_reject" type="object"
                            string="Reject"
                            invisible="status != 'pending'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="vendor_id"/>
                            <field name="window_days"/>
                            <field name="proposed_at" readonly="1"/>
                            <field name="reviewed_at" readonly="1"/>
                            <field name="reviewed_by_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_lines" readonly="1"/>
                            <field name="original_total" readonly="1"/>
                            <field name="estimated_saving" readonly="1"/>
                            <field name="saving_pct" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="POs in proposal">
                            <field name="item_ids" readonly="1">
                                <list>
                                    <field name="purchase_order_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kob_po_consolidation" model="ir.actions.act_window">
        <field name="name">PO Consolidation</field>
        <field name="res_model">kob.po.consolidation.proposal</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_kob_po_consolidation"
        name="PO Consolidation"
        parent="menu_kob_purchase_pro_root"
        action="action_kob_po_consolidation"
        sequence="40"/>
</odoo>
