<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kob_procurement_budget_list" model="ir.ui.view">
        <field name="name">kob.procurement.budget.list</field>
        <field name="model">kob.procurement.budget</field>
        <field name="arch" type="xml">
            <list string="Procurement Budgets">
                <field name="name"/>
                <field name="department"/>
                <field name="project_code"/>
                <field name="fiscal_year"/>
                <field name="period_from"/>
                <field name="period_to"/>
                <field name="state"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'active'"
                       decoration-muted="state in ('closed','cancelled')"/>
                <field name="total_budget" sum="Total"/>
                <field name="committed_amount" sum="Committed"/>
                <field name="spent_amount" sum="Spent"/>
                <field name="remaining_amount" sum="Remaining"
                       decoration-danger="remaining_amount &lt; 0"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_kob_procurement_budget_form" model="ir.ui.view">
        <field name="name">kob.procurement.budget.form</field>
        <field name="model">kob.procurement.budget</field>
        <field name="arch" type="xml">
            <form string="Procurement Budget">
                <header>
                    <button name="action_activate" type="object"
                            string="Activate" class="oe_highlight"
                            invisible="state != 'draft'"/>
                    <button name="action_close" type="object"
                            string="Close"
                            invisible="state != 'active'"/>
                    <button name="action_cancel" type="object"
                            string="Cancel"
                            invisible="state in ('closed','cancelled')"/>
                    <button name="refresh_committed" type="object"
                            string="Refresh from POs"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,active,closed"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1><field name="name"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="department"/>
                            <field name="project_code"/>
                            <field name="fiscal_year"/>
                            <field name="period_from"/>
                            <field name="period_to"/>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                            <field name="owner_id"/>
                            <field name="auto_block_overrun"/>
                        </group>
                        <group>
                            <field name="total_budget"/>
                            <field name="committed_amount" readonly="1"/>
                            <field name="spent_amount" readonly="1"/>
                            <field name="remaining_amount" readonly="1"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Purchase Orders">
                            <field name="purchase_order_ids" readonly="1">
                                <list>
                                    <field name="name"/>
                                    <field name="partner_id"/>
                                    <field name="date_order"/>
                                    <field name="state"/>
                                    <field name="amount_total" sum="Total"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes"><field name="note"/></page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kob_procurement_budget" model="ir.actions.act_window">
        <field name="name">Procurement Budgets</field>
        <field name="res_model">kob.procurement.budget</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_kob_procurement_budget"
        name="Procurement Budgets"
        parent="menu_kob_purchase_pro_root"
        action="action_kob_procurement_budget"
        sequence="20"/>
</odoo>
