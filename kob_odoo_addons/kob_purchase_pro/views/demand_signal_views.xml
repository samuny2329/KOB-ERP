<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kob_demand_signal_list" model="ir.ui.view">
        <field name="name">kob.demand.signal.list</field>
        <field name="model">kob.demand.signal</field>
        <field name="arch" type="xml">
            <list string="Demand Signals">
                <field name="computed_at"/>
                <field name="product_id"/>
                <field name="vendor_id"/>
                <field name="platform"/>
                <field name="avg_daily_sales"/>
                <field name="lead_time_days"/>
                <field name="current_on_hand"/>
                <field name="suggested_qty"
                       decoration-warning="suggested_qty &gt; 0"/>
                <field name="suggested_price"/>
                <field name="status"
                       decoration-info="status == 'open'"
                       decoration-success="status == 'converted'"
                       decoration-muted="status == 'ignored'"/>
                <field name="converted_po_id"/>
            </list>
        </field>
    </record>

    <record id="view_kob_demand_signal_form" model="ir.ui.view">
        <field name="name">kob.demand.signal.form</field>
        <field name="model">kob.demand.signal</field>
        <field name="arch" type="xml">
            <form string="Demand Signal">
                <header>
                    <button name="action_convert_to_rfq" type="object"
                            string="Convert to RFQ" class="oe_highlight"
                            invisible="status != 'open'"/>
                    <button name="action_ignore" type="object"
                            string="Ignore"
                            invisible="status != 'open'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="vendor_id"/>
                            <field name="platform"/>
                            <field name="computed_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="avg_daily_sales"/>
                            <field name="lead_time_days"/>
                            <field name="safety_stock"/>
                            <field name="current_on_hand"/>
                            <field name="suggested_qty"/>
                            <field name="suggested_price"/>
                            <field name="converted_po_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kob_demand_signal" model="ir.actions.act_window">
        <field name="name">Demand Signals</field>
        <field name="res_model">kob.demand.signal</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_kob_demand_signal"
        name="Demand Signals"
        parent="menu_kob_purchase_pro_root"
        action="action_kob_demand_signal"
        sequence="30"/>
</odoo>
