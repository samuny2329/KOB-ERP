<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kob_vendor_performance_list" model="ir.ui.view">
        <field name="name">kob.vendor.performance.list</field>
        <field name="model">kob.vendor.performance</field>
        <field name="arch" type="xml">
            <list string="Vendor Performance">
                <field name="vendor_id"/>
                <field name="period_year"/>
                <field name="period_month"/>
                <field name="on_time_rate"/>
                <field name="fill_rate"/>
                <field name="quality_rate"/>
                <field name="price_stability"/>
                <field name="overall_score"
                       decoration-success="overall_score &gt;= 85"
                       decoration-warning="overall_score &lt; 85 and overall_score &gt;= 65"
                       decoration-danger="overall_score &lt; 65"/>
                <field name="po_count"/>
                <field name="receipt_count"/>
                <field name="computed_at"/>
            </list>
        </field>
    </record>

    <record id="view_kob_vendor_performance_form" model="ir.ui.view">
        <field name="name">kob.vendor.performance.form</field>
        <field name="model">kob.vendor.performance</field>
        <field name="arch" type="xml">
            <form string="Vendor Performance">
                <sheet>
                    <group>
                        <group>
                            <field name="vendor_id"/>
                            <field name="period_year"/>
                            <field name="period_month"/>
                            <field name="computed_at" readonly="1"/>
                        </group>
                        <group>
                            <field name="on_time_rate"/>
                            <field name="fill_rate"/>
                            <field name="quality_rate"/>
                            <field name="price_stability"/>
                            <field name="overall_score" readonly="1"/>
                            <field name="po_count" readonly="1"/>
                            <field name="receipt_count" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kob_vendor_performance" model="ir.actions.act_window">
        <field name="name">Vendor Performance</field>
        <field name="res_model">kob.vendor.performance</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Sequence=5 makes Vendor Performance the first (= default) entry
         under the KOB Purchase Pro menu. -->
    <menuitem
        id="menu_kob_vendor_performance"
        name="Vendor Performance"
        parent="menu_kob_purchase_pro_root"
        action="action_kob_vendor_performance"
        sequence="5"/>

    <!-- Vendor compliance docs -->
    <record id="view_kob_vendor_document_list" model="ir.ui.view">
        <field name="name">kob.vendor.document.list</field>
        <field name="model">kob.vendor.document</field>
        <field name="arch" type="xml">
            <list string="Vendor Documents"
                  decoration-warning="is_expiring"
                  decoration-muted="not active">
                <field name="vendor_id"/>
                <field name="doc_type"/>
                <field name="title"/>
                <field name="reference"/>
                <field name="issued_date"/>
                <field name="expiry_date"/>
                <field name="alert_days_before"/>
                <field name="active"/>
                <field name="is_expiring" string="Expiring?" optional="show"/>
            </list>
        </field>
    </record>

    <record id="view_kob_vendor_document_form" model="ir.ui.view">
        <field name="name">kob.vendor.document.form</field>
        <field name="model">kob.vendor.document</field>
        <field name="arch" type="xml">
            <form string="Vendor Document">
                <sheet>
                    <group>
                        <group>
                            <field name="vendor_id"/>
                            <field name="doc_type"/>
                            <field name="title"/>
                            <field name="reference"/>
                        </group>
                        <group>
                            <field name="issued_date"/>
                            <field name="expiry_date"/>
                            <field name="alert_days_before"/>
                            <field name="file_url" widget="url"/>
                            <field name="active"/>
                        </group>
                    </group>
                    <notebook><page string="Notes"><field name="note"/></page></notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kob_vendor_document" model="ir.actions.act_window">
        <field name="name">Vendor Documents</field>
        <field name="res_model">kob.vendor.document</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem
        id="menu_kob_vendor_document"
        name="Vendor Documents"
        parent="menu_kob_purchase_pro_root"
        action="action_kob_vendor_document"
        sequence="15"/>
</odoo>
