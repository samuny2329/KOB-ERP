<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Monthly depreciation posting — runs on the 1st of every month -->
    <record id="ir_cron_post_monthly_depreciation" model="ir.cron">
        <field name="name">KOB: Post Monthly Depreciation</field>
        <field name="model_id" ref="model_kob_fixed_asset"/>
        <field name="state">code</field>
        <field name="code">model.cron_post_monthly_depreciation()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active">True</field>
    </record>

    <!-- Recompute book value daily (cheap; idempotent) -->
    <record id="ir_cron_recompute_asset_book_value" model="ir.cron">
        <field name="name">KOB: Recompute Asset Book Value</field>
        <field name="model_id" ref="model_kob_fixed_asset"/>
        <field name="state">code</field>
        <field name="code">model.cron_recompute_book_value()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <field name="active">True</field>
    </record>
</odoo>
