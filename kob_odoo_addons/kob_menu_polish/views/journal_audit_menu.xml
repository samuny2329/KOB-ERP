<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- ============================================================ -->
    <!-- Journal Audit & friends — open instantly, no wizard popup     -->
    <!--                                                                -->
    <!-- OCA wizards require date_from/date_to. We auto-fill            -->
    <!-- (current FY start → today) via server actions and immediately  -->
    <!-- call button_export_html() so the user lands on the report.     -->
    <!-- ============================================================ -->

    <record id="server_open_journal_audit" model="ir.actions.server">
        <field name="name">Journal Audit (auto)</field>
        <field name="model_id" ref="account_financial_report.model_journal_ledger_report_wizard"/>
        <field name="state">code</field>
        <field name="code"><![CDATA[
today = fields.Date.context_today(env.user)
fy_start = today.replace(month=1, day=1)
wiz = env["journal.ledger.report.wizard"].create({
    "company_id": env.company.id,
    "date_from": fy_start,
    "date_to": today,
    "target_move": "posted",
})
action = wiz.button_export_html()
]]></field>
    </record>

    <record id="server_open_general_ledger" model="ir.actions.server">
        <field name="name">General Ledger (auto)</field>
        <field name="model_id" ref="account_financial_report.model_general_ledger_report_wizard"/>
        <field name="state">code</field>
        <field name="code"><![CDATA[
today = fields.Date.context_today(env.user)
fy_start = today.replace(month=1, day=1)
wiz = env["general.ledger.report.wizard"].create({
    "company_id": env.company.id,
