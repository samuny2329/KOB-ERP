    <!-- New "Audit Reports" section under Accounting → Reporting -->
    <menuitem id="menu_account_audit_reports"
              name="Audit Reports"
              parent="account.menu_finance_reports"
              sequence="35"/>

    <menuitem id="menu_journal_audit"
              name="Journal Audit"
              parent="menu_account_audit_reports"
              action="server_open_journal_audit"
              sequence="10"/>

    <menuitem id="menu_audit_general_ledger"
              name="General Ledger"
              parent="menu_account_audit_reports"
              action="server_open_general_ledger"
              sequence="20"/>

    <menuitem id="menu_audit_trial_balance"
              name="Trial Balance"
              parent="menu_account_audit_reports"
              action="server_open_trial_balance"
              sequence="30"/>

    <menuitem id="menu_audit_open_items"
              name="Open Items"
              parent="menu_account_audit_reports"
              action="server_open_open_items"
              sequence="40"/>

    <menuitem id="menu_audit_aged_partner"
              name="Aged Partner Balance"
              parent="menu_account_audit_reports"
              action="server_open_aged_partner"
              sequence="50"/>

    <!-- Replace OCA report wizard menus with auto-open server actions -->
    <record id="account_financial_report.menu_journal_ledger_wizard" model="ir.ui.menu">
        <field name="name">Journal Audit</field>
        <field name="action" ref="server_open_journal_audit"/>
    </record>
    <record id="account_financial_report.menu_general_ledger_wizard" model="ir.ui.menu">
        <field name="action" ref="server_open_general_ledger"/>
    </record>
    <record id="account_financial_report.menu_trial_balance_wizard" model="ir.ui.menu">
        <field name="action" ref="server_open_trial_balance"/>
    </record>
    <record id="account_financial_report.menu_open_items_wizard" model="ir.ui.menu">
        <field name="action" ref="server_open_open_items"/>
    </record>
    <record id="account_financial_report.menu_aged_partner_balance_wizard" model="ir.ui.menu">
        <field name="action" ref="server_open_aged_partner"/>
    </record>
    <record id="account_financial_report.menu_vat_report_wizard" model="ir.ui.menu">
        <field name="action" ref="server_open_vat_report"/>
    </record>

    <!-- UAT-style report menus (Balance Sheet / P&L / Tax Return / Aged
         Receivable / Aged Payable / Purchase & Sale Tax Report) were
         created without XML IDs. Re-point them to auto-open server actions
         by name. -->
    <record id="server_repoint_uat_menus" model="ir.actions.server">
        <field name="name">KOB: re-point UAT report menus to auto-open</field>
        <field name="model_id" ref="base.model_ir_ui_menu"/>
        <field name="state">code</field>
        <field name="code"><![CDATA[
mapping = {
    "Balance Sheet":        "kob_menu_polish.server_open_general_ledger",
    "Profit and Loss":      "kob_menu_polish.server_open_trial_balance",
    "Profit and Loss Default": "kob_menu_polish.server_open_trial_balance",
    "Tax Return":           "kob_menu_polish.server_open_vat_report",
    "Purchase Tax Report":  "kob_menu_polish.server_open_vat_report",
    "Sale Tax Report":      "kob_menu_polish.server_open_vat_report",
    "Aged Receivable":      "kob_menu_polish.server_open_aged_receivable",
    "Aged Payable":         "kob_menu_polish.server_open_aged_payable",
}
for menu_name, xmlid in mapping.items():
    server = env.ref(xmlid, raise_if_not_found=False)
    if not server:
        continue
    target_action = "ir.actions.server,%d" % server.id
    menus = env["ir.ui.menu"].search([("name", "=", menu_name)])
    if menus:
        menus.write({"action": target_action})
]]></field>
    </record>

    <function model="ir.actions.server" name="run">
        <value model="ir.actions.server" eval="[ref('server_repoint_uat_menus')]"/>
    </function>
</odoo>
