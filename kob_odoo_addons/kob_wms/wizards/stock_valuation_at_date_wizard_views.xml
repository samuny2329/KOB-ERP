<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wms_stock_valuation_date_wizard_form" model="ir.ui.view">
        <field name="name">wms.stock.valuation.date.wizard.form</field>
        <field name="model">wms.stock.valuation.date.wizard</field>
        <field name="arch" type="xml">
            <form string="Stock Valuation at Date">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Pick a historical date and time to view the Stock
                        Valuation snapshot. All stock.move records completed
                        AFTER the chosen point are excluded — useful for
                        period-end reconciliation, audit trails, and "what
                        was on hand at midnight last Friday?" questions.
                    </div>
                    <group>
                        <field name="snapshot_date"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_open_snapshot" type="object"
                            string="Open Snapshot" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_wms_stock_valuation_date_wizard"
            model="ir.actions.act_window">
        <field name="name">Stock Valuation at Date</field>
        <field name="res_model">wms.stock.valuation.date.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <!-- No separate menu — wizard is reached from the 'Valuation at
         Date' button at the top of the Stock Valuation list view. -->
</odoo>
