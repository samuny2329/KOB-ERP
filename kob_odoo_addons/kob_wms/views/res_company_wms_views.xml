<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Add WMS toggle to Company form -->
    <record id="view_company_form_wms" model="ir.ui.view">
        <field name="name">res.company.form.wms</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="📦 KOB WMS" name="wms_settings">
                    <group string="Workflow">
                        <field name="wms_skip_pack"/>
                        <p class="text-muted oe_grey" colspan="2">
                            <strong>Skip Pack mode:</strong> When ON, the
                            <em>Pack</em> stage is bypassed. Picked orders go
                            straight to <em>Outbound</em>, where stock cut and
                            invoice creation happen. Use this temporarily when
                            the pack scanner station is offline. Turn OFF to
                            restore the normal Pick → Pack → Out flow.
                        </p>
                    </group>
                </page>
            </notebook>
        </field>
    </record>

    <!-- Direct menu shortcut to toggle (admin convenience) -->
    <record id="action_wms_skip_pack_settings" model="ir.actions.act_window">
        <field name="name">WMS — Skip Pack Settings</field>
        <field name="res_model">res.company</field>
        <field name="view_mode">list,form</field>
        <field name="context">{'search_default_my_company': 1}</field>
    </record>

    <menuitem id="menu_wms_skip_pack_settings"
              name="⚙ Skip Pack Toggle"
              parent="kob_wms.menu_kob_wms_root"
              action="action_wms_skip_pack_settings"
              sequence="999"
              groups="base.group_system"/>

</odoo>
