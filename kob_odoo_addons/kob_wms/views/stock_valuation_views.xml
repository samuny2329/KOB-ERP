<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Custom Stock Valuation list view — Odoo 18-style report on
         stock.move with signed Quantity + Total Value, matching the
         enterprise/legacy 'Stock Valuation' page UX. -->
    <record id="view_stock_valuation_list_kob" model="ir.ui.view">
        <field name="name">stock.move.valuation.list.kob</field>
        <field name="model">stock.move</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <list string="Stock Valuation"
                  create="false" edit="false" delete="false"
                  default_order="date desc">
                <header>
                    <button name="%(action_wms_stock_valuation_date_wizard)d"
                            type="action"
                            string="📅 Valuation at Date"
                            class="btn-primary"
                            display="always"/>
                </header>
                <field name="date" widget="datetime"/>
                <field name="reference"/>
                <field name="product_id"/>
                <field name="picking_id" optional="show"/>
                <field name="company_id" optional="hide"
                       groups="base.group_multi_company"/>
                <field name="quantity" sum="Quantity"/>
                <field name="value" sum="Total Value" widget="monetary"/>
                <field name="remaining_qty" optional="hide" sum="Remaining Qty"/>
                <field name="remaining_value" optional="hide"
                       widget="monetary" sum="Remaining Value"/>
                <field name="state" widget="badge" optional="hide"/>
                <field name="is_in" optional="hide"/>
                <field name="is_out" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_stock_valuation_form_kob" model="ir.ui.view">
        <field name="name">stock.move.valuation.form.kob</field>
        <field name="model">stock.move</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <form string="Stock Valuation Detail" create="false" edit="false" delete="false">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="reference" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group string="Move">
                            <field name="date" widget="datetime" readonly="1"/>
                            <field name="product_id" readonly="1"/>
                            <field name="picking_id" readonly="1"/>
                            <field name="state" widget="badge" readonly="1"/>
                            <field name="company_id" readonly="1"
                                   groups="base.group_multi_company"/>
                        </group>
                        <group string="Valuation">
                            <field name="quantity" readonly="1"/>
                            <field name="product_uom_qty" readonly="1"/>
                            <field name="value" widget="monetary" readonly="1"/>
                            <field name="remaining_qty" readonly="1"/>
                            <field name="remaining_value" widget="monetary" readonly="1"/>
                            <field name="is_in" readonly="1"/>
                            <field name="is_out" readonly="1"/>
                        </group>
                    </group>
                    <group string="Source / Destination">
                        <group>
                            <field name="location_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="location_dest_id" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Move Lines">
                            <field name="move_line_ids" readonly="1">
                                <list>
                                    <field name="lot_id"/>
                                    <field name="quantity"/>
                                    <field name="location_id"/>
                                    <field name="location_dest_id"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_stock_valuation_pivot_kob" model="ir.ui.view">
        <field name="name">stock.move.valuation.pivot.kob</field>
        <field name="model">stock.move</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <pivot string="Stock Valuation" sample="1">
                <field name="date" interval="month" type="row"/>
                <field name="product_id" type="row"/>
                <field name="quantity" type="measure"/>
                <field name="value" type="measure"/>
            </pivot>
        </field>
    </record>

    <record id="view_stock_valuation_graph_kob" model="ir.ui.view">
        <field name="name">stock.move.valuation.graph.kob</field>
        <field name="model">stock.move</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <graph string="Stock Valuation" type="line" sample="1">
                <field name="date" interval="month"/>
                <field name="value" type="measure"/>
            </graph>
        </field>
    </record>

    <record id="view_stock_valuation_search_kob" model="ir.ui.view">
        <field name="name">stock.move.valuation.search.kob</field>
        <field name="model">stock.move</field>
        <field name="priority">20</field>
        <field name="arch" type="xml">
            <search>
                <field name="reference"/>
                <field name="product_id"/>
                <field name="picking_id"/>
                <field name="company_id" groups="base.group_multi_company"/>
                <filter name="done" string="Done"
                        domain="[('state','=','done')]"/>
                <filter name="incoming" string="Incoming (IN)"
                        domain="[('is_in','=',True)]"/>
                <filter name="outgoing" string="Outgoing (OUT)"
                        domain="[('is_out','=',True)]"/>
                <separator/>
                <filter name="grp_product" string="Product"
                        context="{'group_by': 'product_id'}"/>
                <filter name="grp_date" string="Date"
                        context="{'group_by': 'date:month'}"/>
                <filter name="grp_company" string="Company"
                        context="{'group_by': 'company_id'}"
                        groups="base.group_multi_company"/>
            </search>
        </field>
    </record>

    <!-- Override existing standard action 478 (stock_account.stock_move_valuation_action)
         to use list+pivot+graph views and rename to 'Stock Valuation'. -->
    <record id="stock_account.stock_move_valuation_action"
            model="ir.actions.act_window">
        <field name="name">Stock Valuation</field>
        <field name="view_mode">list,form,pivot,graph</field>
        <field name="search_view_id" ref="view_stock_valuation_search_kob"/>
    </record>

    <record id="stock_valuation_action_view_list"
            model="ir.actions.act_window.view">
        <field name="sequence">1</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="view_stock_valuation_list_kob"/>
        <field name="act_window_id" ref="stock_account.stock_move_valuation_action"/>
    </record>

    <record id="stock_valuation_action_view_form"
            model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">form</field>
        <field name="view_id" ref="view_stock_valuation_form_kob"/>
        <field name="act_window_id" ref="stock_account.stock_move_valuation_action"/>
    </record>

    <record id="stock_valuation_action_view_pivot"
            model="ir.actions.act_window.view">
        <field name="sequence">2</field>
        <field name="view_mode">pivot</field>
        <field name="view_id" ref="view_stock_valuation_pivot_kob"/>
        <field name="act_window_id" ref="stock_account.stock_move_valuation_action"/>
    </record>

    <record id="stock_valuation_action_view_graph"
            model="ir.actions.act_window.view">
        <field name="sequence">4</field>
        <field name="view_mode">graph</field>
        <field name="view_id" ref="view_stock_valuation_graph_kob"/>
        <field name="act_window_id" ref="stock_account.stock_move_valuation_action"/>
    </record>


</odoo>
