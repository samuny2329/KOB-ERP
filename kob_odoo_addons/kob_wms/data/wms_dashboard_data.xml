<?xml version="1.0" encoding="utf-8"?>
<!-- noupdate="1": binary data ไม่ reload บน -u (known Odoo limitation)
     ถ้าต้องการ reload ให้เปลี่ยน XML ID แล้ว upgrade ใหม่ -->
<odoo noupdate="1">

    <record id="dashboard_group_kob_wms" model="spreadsheet.dashboard.group">
        <field name="name">KOB WMS</field>
        <field name="sequence">1</field>
    </record>

    <!-- 1. WMS Overview — v2 (XML ID เปลี่ยนเพื่อบังคับ fresh load) -->
    <record id="dashboard_kob_wms_overview_v2" model="spreadsheet.dashboard">
        <field name="name">WMS Overview</field>
        <field name="spreadsheet_binary_data"
               type="base64"
               file="kob_wms/data/files/kob_wms_dashboard.json"/>
        <field name="dashboard_group_id" ref="dashboard_group_kob_wms"/>
        <field name="main_data_model_ids"
               eval="[(4, ref('kob_wms.model_wms_sales_order'))]"/>
        <field name="group_ids"
               eval="[Command.link(ref('kob_wms.group_wms_worker'))]"/>
        <field name="is_published">True</field>
        <field name="sequence">10</field>
    </record>

    <!-- 2. KPI Performance — v2 -->
    <record id="dashboard_kob_wms_kpi_v2" model="spreadsheet.dashboard">
        <field name="name">KPI Performance</field>
        <field name="spreadsheet_binary_data"
               type="base64"
               file="kob_wms/data/files/kob_wms_kpi_dashboard.json"/>
        <field name="dashboard_group_id" ref="dashboard_group_kob_wms"/>
        <field name="main_data_model_ids"
               eval="[(4, ref('kob_wms.model_wms_worker_performance'))]"/>
        <field name="group_ids"
               eval="[Command.link(ref('kob_wms.group_wms_supervisor'))]"/>
        <field name="is_published">True</field>
        <field name="sequence">20</field>
    </record>

    <!-- 3. WMS Operations — v2 -->
    <record id="dashboard_kob_wms_operations_v2" model="spreadsheet.dashboard">
        <field name="name">WMS Operations</field>
        <field name="spreadsheet_binary_data"
               type="base64"
               file="kob_wms/data/files/kob_wms_operations_dashboard.json"/>
        <field name="dashboard_group_id" ref="dashboard_group_kob_wms"/>
        <field name="main_data_model_ids"
               eval="[(4, ref('kob_wms.model_wms_sales_order')),
                       (4, ref('kob_wms.model_wms_count_session')),
                       (4, ref('kob_wms.model_wms_count_adjustment')),
                       (4, ref('kob_wms.model_wms_pickface'))]"/>
        <field name="group_ids"
               eval="[Command.link(ref('kob_wms.group_wms_supervisor'))]"/>
        <field name="is_published">True</field>
        <field name="sequence">30</field>
    </record>

    <!-- 4. Count Adjustments — v2 -->
    <record id="dashboard_kob_wms_count_adj_v2" model="spreadsheet.dashboard">
        <field name="name">Count Adjustments</field>
        <field name="spreadsheet_binary_data"
               type="base64"
               file="kob_wms/data/files/kob_wms_count_dashboard.json"/>
        <field name="dashboard_group_id" ref="dashboard_group_kob_wms"/>
        <field name="main_data_model_ids"
               eval="[(4, ref('kob_wms.model_wms_count_session')),
                       (4, ref('kob_wms.model_wms_count_adjustment'))]"/>
        <field name="group_ids"
               eval="[Command.link(ref('kob_wms.group_wms_supervisor'))]"/>
        <field name="is_published">True</field>
        <field name="sequence">25</field>
    </record>

</odoo>
