<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">

    <record id="dashboard_group_kob_wms" model="spreadsheet.dashboard.group">
        <field name="name">KOB WMS</field>
        <field name="sequence">1</field>
    </record>

    <!-- v4: ไม่ใส่ group_ids → ทุก user เห็นได้ (ตัดสาเหตุ permission ออก) -->

    <record id="dashboard_kob_wms_overview_v4" model="spreadsheet.dashboard">
        <field name="name">WMS Overview</field>
        <field name="spreadsheet_binary_data"
               type="base64"
               file="kob_wms/data/files/kob_wms_dashboard.json"/>
        <field name="dashboard_group_id" ref="dashboard_group_kob_wms"/>
        <field name="is_published">True</field>
        <field name="sequence">10</field>
    </record>

    <record id="dashboard_kob_wms_kpi_v4" model="spreadsheet.dashboard">
        <field name="name">KPI Performance</field>
        <field name="spreadsheet_binary_data"
               type="base64"
               file="kob_wms/data/files/kob_wms_kpi_dashboard.json"/>
        <field name="dashboard_group_id" ref="dashboard_group_kob_wms"/>
        <field name="is_published">True</field>
        <field name="sequence">20</field>
    </record>

    <record id="dashboard_kob_wms_operations_v4" model="spreadsheet.dashboard">
        <field name="name">WMS Operations</field>
        <field name="spreadsheet_binary_data"
               type="base64"
               file="kob_wms/data/files/kob_wms_operations_dashboard.json"/>
        <field name="dashboard_group_id" ref="dashboard_group_kob_wms"/>
        <field name="is_published">True</field>
        <field name="sequence">30</field>
    </record>

    <record id="dashboard_kob_wms_count_adj_v4" model="spreadsheet.dashboard">
        <field name="name">Count Adjustments</field>
        <field name="spreadsheet_binary_data"
               type="base64"
               file="kob_wms/data/files/kob_wms_count_dashboard.json"/>
        <field name="dashboard_group_id" ref="dashboard_group_kob_wms"/>
        <field name="is_published">True</field>
        <field name="sequence">25</field>
    </record>

</odoo>
