<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mfg_production_signal_list" model="ir.ui.view">
        <field name="name">mfg.production.signal.list</field>
        <field name="model">mfg.production.signal</field>
        <field name="arch" type="xml">
            <list string="Production Signals">
                <field name="computed_at"/>
                <field name="product_id"/>
                <field name="bom_id"/>
                <field name="platform"/>
                <field name="avg_daily_demand"/>
                <field name="lead_time_days"/>
                <field name="current_stock"/>
                <field name="wip_qty"/>
                <field name="suggested_qty"
                       decoration-warning="suggested_qty &gt; 0"/>
                <field name="status"
                       decoration-info="status == 'open'"
                       decoration-success="status == 'converted'"
                       decoration-muted="status == 'ignored'"/>
                <field name="converted_mo_id"/>
            </list>
        </field>
    </record>
    <record id="view_mfg_production_signal_form" model="ir.ui.view">
        <field name="name">mfg.production.signal.form</field>
        <field name="model">mfg.production.signal</field>
        <field name="arch" type="xml">
            <form string="Production Signal">
                <header>
                    <button name="action_convert_to_mo" type="object"
                            string="Convert to MO" class="oe_highlight"
                            invisible="status != 'open'"/>
                    <button name="action_ignore" type="object"
                            string="Ignore"
                            invisible="status != 'open'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="bom_id"/>
                            <field name="platform"/>
                            <field name="computed_at"/>
                        </group>
                        <group>
                            <field name="avg_daily_demand"/>
                            <field name="lead_time_days"/>
                            <field name="current_stock"/>
                            <field name="wip_qty"/>
                            <field name="suggested_qty"/>
                            <field name="converted_mo_id" readonly="1"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_mfg_production_signal" model="ir.actions.act_window">
        <field name="name">Production Signals</field>
        <field name="res_model">mfg.production.signal</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem
        id="menu_mfg_production_signal"
        name="Production Signals"
        parent="menu_kob_mfg_pro_root"
        action="action_mfg_production_signal"
        sequence="30"/>
</odoo>
