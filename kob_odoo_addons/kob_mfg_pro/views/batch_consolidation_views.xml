<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mfg_batch_consolidation_list" model="ir.ui.view">
        <field name="name">mfg.batch.consolidation.list</field>
        <field name="model">mfg.batch.consolidation</field>
        <field name="arch" type="xml">
            <list string="Batch Consolidations">
                <field name="proposed_at"/>
                <field name="product_id"/>
                <field name="total_mos"/>
                <field name="total_qty"/>
                <field name="setup_saving_minutes"/>
                <field name="status"
                       decoration-info="status == 'pending'"
                       decoration-success="status == 'accepted'"
                       decoration-muted="status == 'rejected'"/>
            </list>
        </field>
    </record>
    <record id="view_mfg_batch_consolidation_form" model="ir.ui.view">
        <field name="name">mfg.batch.consolidation.form</field>
        <field name="model">mfg.batch.consolidation</field>
        <field name="arch" type="xml">
            <form string="Batch Consolidation">
                <header>
                    <button name="action_accept" type="object"
                            string="Accept" class="oe_highlight"
                            invisible="status != 'pending'"/>
                    <button name="action_reject" type="object"
                            string="Reject"
                            invisible="status != 'pending'"/>
                    <field name="status" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="product_id"/>
                            <field name="window_days"/>
                            <field name="proposed_at" readonly="1"/>
                            <field name="reviewed_at" readonly="1"/>
                            <field name="reviewed_by_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="total_mos" readonly="1"/>
                            <field name="total_qty" readonly="1"/>
                            <field name="setup_saving_minutes" readonly="1"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="MOs">
                            <field name="item_ids" readonly="1">
                                <list><field name="mo_id"/></list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="action_mfg_batch_consolidation" model="ir.actions.act_window">
        <field name="name">Batch Consolidations</field>
        <field name="res_model">mfg.batch.consolidation</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem
        id="menu_mfg_batch_consolidation"
        name="Batch Consolidation"
        parent="menu_kob_mfg_pro_root"
        action="action_mfg_batch_consolidation"
        sequence="40"/>
</odoo>
