<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_kob_poll_list" model="ir.ui.view">
        <field name="name">kob.poll.list</field>
        <field name="model">kob.poll</field>
        <field name="arch" type="xml">
            <list>
                <field name="question"/>
                <field name="channel_id"/>
                <field name="creator_id"/>
                <field name="total_votes"/>
                <field name="expires_at"/>
                <field name="is_closed"/>
            </list>
        </field>
    </record>

    <record id="view_kob_poll_form" model="ir.ui.view">
        <field name="name">kob.poll.form</field>
        <field name="model">kob.poll</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <h1><field name="question" placeholder="What's the question?"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="channel_id"/>
                            <field name="creator_id" readonly="1"/>
                        </group>
                        <group>
                            <field name="expires_at"/>
                            <field name="is_closed"/>
                            <field name="total_votes"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Options">
                            <field name="option_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="label"/>
                                </list>
                            </field>
                        </page>
                        <page string="Votes">
                            <field name="vote_ids" readonly="1">
                                <list>
                                    <field name="user_id"/>
                                    <field name="option_id"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_kob_poll" model="ir.actions.act_window">
        <field name="name">Polls</field>
        <field name="res_model">kob.poll</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_kob_poll"
              name="Polls"
              parent="mail.discuss_channel_menu_settings"
              action="action_kob_poll"
              sequence="60"/>
</odoo>
