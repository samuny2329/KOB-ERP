<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mea_tariff_list" model="ir.ui.view">
        <field name="name">mea.tariff.list</field>
        <field name="model">mea.tariff</field>
        <field name="arch" type="xml">
            <list string="Tariffs" class="o_mea_list">
                <field name="code"/>
                <field name="name"/>
                <field name="is_tou" widget="boolean_toggle"/>
                <field name="voltage_level"/>
                <field name="peak_rate" optional="show"/>
                <field name="off_peak_rate" optional="show"/>
                <field name="flat_rate" optional="hide"/>
                <field name="service_charge" optional="show"/>
                <field name="effective_date"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_mea_tariff_form" model="ir.ui.view">
        <field name="name">mea.tariff.form</field>
        <field name="model">mea.tariff</field>
        <field name="arch" type="xml">
            <form string="Tariff">
                <sheet>
                    <div class="oe_title">
                        <label for="code"/>
                        <h1><field name="code" placeholder="3.2.3"/></h1>
                        <field name="name" placeholder="TOU Medium Voltage 12-24kV"/>
                    </div>
                    <group>
                        <group>
                            <field name="is_tou"/>
                            <field name="voltage_level"/>
                            <field name="effective_date"/>
                            <field name="active"/>
                        </group>
                        <group>
                            <field name="peak_rate" invisible="not is_tou"/>
                            <field name="off_peak_rate" invisible="not is_tou"/>
                            <field name="flat_rate" invisible="is_tou"/>
                            <field name="service_charge"/>
                            <field name="demand_charge" invisible="not is_tou"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Progressive Tiers" invisible="is_tou">
                            <field name="tier_ids">
                                <list editable="bottom">
                                    <field name="kwh_from"/>
                                    <field name="kwh_to"/>
                                    <field name="rate"/>
                                    <field name="note"/>
                                </list>
                            </field>
                        </page>
                        <page string="Notes">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mea_tariff" model="ir.actions.act_window">
        <field name="name">Tariffs</field>
        <field name="res_model">mea.tariff</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
