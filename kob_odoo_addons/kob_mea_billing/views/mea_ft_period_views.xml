<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mea_ft_period_list" model="ir.ui.view">
        <field name="name">mea.ft.period.list</field>
        <field name="model">mea.ft.period</field>
        <field name="arch" type="xml">
            <list string="Ft Periods" default_order="period_start desc" class="o_mea_list">
                <field name="period_start"/>
                <field name="period_end"/>
                <field name="ft_rate" sum="-"/>
                <field name="change_satang" widget="badge"
                       decoration-success="change_satang &lt; 0"
                       decoration-danger="change_satang &gt; 0"/>
                <field name="published_date"/>
                <field name="source_url" widget="url" optional="hide"/>
            </list>
        </field>
    </record>

    <record id="view_mea_ft_period_form" model="ir.ui.view">
        <field name="name">mea.ft.period.form</field>
        <field name="model">mea.ft.period</field>
        <field name="arch" type="xml">
            <form string="Ft Period">
                <sheet>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="period_start"/>
                            <field name="period_end"/>
                            <field name="published_date"/>
                        </group>
                        <group>
                            <field name="ft_rate"/>
                            <field name="change_satang"/>
                            <field name="source_url" widget="url"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Notes">
                            <field name="note" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_mea_ft_period" model="ir.actions.act_window">
        <field name="name">Ft Periods</field>
        <field name="res_model">mea.ft.period</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
