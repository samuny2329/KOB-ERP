<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="0">

        <record id="module_category_kob_mea" model="ir.module.category">
            <field name="name">KOB MEA</field>
            <field name="description">KOB MEA Billing access levels</field>
            <field name="sequence">25</field>
        </record>

        <record id="privilege_kob_mea" model="res.groups.privilege">
            <field name="name">KOB MEA Access</field>
            <field name="category_id" ref="module_category_kob_mea"/>
            <field name="sequence">25</field>
        </record>

        <record id="group_mea_user" model="res.groups">
            <field name="name">MEA / User (Read)</field>
            <field name="privilege_id" ref="privilege_kob_mea"/>
            <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        </record>

        <record id="group_mea_manager" model="res.groups">
            <field name="name">MEA / Manager</field>
            <field name="privilege_id" ref="privilege_kob_mea"/>
            <field name="implied_ids" eval="[(4, ref('group_mea_user'))]"/>
            <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        </record>

    </data>

    <data noupdate="1">

        <record id="rule_mea_meter_company" model="ir.rule">
            <field name="name">MEA Meter: multi-company</field>
            <field name="model_id" ref="model_mea_meter"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
            <field name="perm_read" eval="True"/>
            <field name="perm_write" eval="True"/>
            <field name="perm_create" eval="True"/>
            <field name="perm_unlink" eval="True"/>
        </record>

        <record id="rule_mea_bill_history_company" model="ir.rule">
            <field name="name">MEA Bill History: multi-company</field>
            <field name="model_id" ref="model_mea_bill_history"/>
            <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        </record>

    </data>
</odoo>
