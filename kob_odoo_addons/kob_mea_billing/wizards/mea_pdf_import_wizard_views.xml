<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mea_pdf_import_wizard_form" model="ir.ui.view">
        <field name="name">mea.pdf.import.wizard.form</field>
        <field name="model">mea.pdf.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import MEA Bill PDF">
                <sheet>
                    <group string="Source">
                        <field name="pdf_file" filename="pdf_filename" required="1"/>
                        <field name="pdf_filename" invisible="1"/>
                        <field name="meter_id" options="{'no_create': True}"
                               help="Optional. Leave empty to auto-match by CA Number from PDF."/>
                        <field name="auto_confirm"/>
                    </group>
                    <group string="Preview" invisible="not preview_summary">
                        <field name="preview_summary" readonly="1" nolabel="1"/>
                    </group>
                    <notebook invisible="not preview_text">
                        <page string="Raw Text">
                            <field name="preview_text" readonly="1" nolabel="1"/>
                        </page>
                    </notebook>
                </sheet>
                <footer>
                    <button name="action_preview" type="object" string="Preview" class="btn-secondary"/>
                    <button name="action_import" type="object" string="Import" class="btn-primary"/>
                    <button special="cancel" string="Cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mea_pdf_import_wizard" model="ir.actions.act_window">
        <field name="name">Import MEA Bill PDF</field>
        <field name="res_model">mea.pdf.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
