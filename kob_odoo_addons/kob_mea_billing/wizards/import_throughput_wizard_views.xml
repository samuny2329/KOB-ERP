<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mea_throughput_import_wizard_form" model="ir.ui.view">
        <field name="name">mea.throughput.import.wizard.form</field>
        <field name="model">mea.throughput.import.wizard</field>
        <field name="arch" type="xml">
            <form string="Import Throughput from Stock Move">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Upload an Odoo <b>Stock Move (stock.move)</b> xlsx export.
                        Rows where <i>Operation Type</i> is
                        <b>BTV-WH2 (Online): Delivery Orders</b> or
                        <b>KOB-WH2 (Online): Delivery Orders</b> will be
                        aggregated by month and written to the matching
                        <i>mea.bill.history</i> records.
                    </div>
                    <group>
                        <group string="Source">
                            <field name="xlsx_file" filename="xlsx_filename" required="1"/>
                            <field name="xlsx_filename" invisible="1"/>
                        </group>
                        <group string="Target">
                            <field name="meter_id" options="{'no_create': True}"/>
                            <field name="overwrite"/>
                        </group>
                    </group>
                    <group string="Result" invisible="not summary">
                        <field name="summary" readonly="1" nolabel="1" widget="text"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_import" type="object"
                            string="Import" class="btn-primary"/>
                    <button special="cancel" string="Close"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mea_throughput_import_wizard" model="ir.actions.act_window">
        <field name="name">Import Throughput (xlsx)</field>
        <field name="res_model">mea.throughput.import.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_mea_throughput_import"
              name="Import Throughput"
              parent="menu_kob_mea_root"
              action="action_mea_throughput_import_wizard"
              sequence="55"/>
</odoo>
