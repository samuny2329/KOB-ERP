<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_mea_calculator_wizard_form" model="ir.ui.view">
        <field name="name">mea.calculator.wizard.form</field>
        <field name="model">mea.calculator.wizard</field>
        <field name="arch" type="xml">
            <form string="MEA What-If Calculator">
                <sheet>
                    <group string="Inputs">
                        <field name="tariff_id" options="{'no_create': True}"/>
                        <field name="is_tou" invisible="1"/>
                        <field name="billing_date"/>
                        <field name="ft_period_id" readonly="1"/>
                        <field name="ft_rate_satang" readonly="1"/>
                    </group>
                    <group string="Energy">
                        <field name="kwh_total" invisible="is_tou"/>
                        <field name="kwh_on_peak" invisible="not is_tou"/>
                        <field name="kwh_off_peak" invisible="not is_tou"/>
                        <field name="demand_kw" invisible="not is_tou"/>
                    </group>
                    <group string="Result" invisible="not total_amount">
                        <field name="energy_charge"/>
                        <field name="demand_charge_amount" invisible="not is_tou"/>
                        <field name="service_charge"/>
                        <field name="ft_amount"/>
                        <field name="subtotal"/>
                        <field name="vat_amount"/>
                        <field name="total_amount" class="oe_subtotal_footer"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_calculate" type="object" string="Calculate" class="btn-primary"/>
                    <button special="cancel" string="Close" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_mea_calculator_wizard" model="ir.actions.act_window">
        <field name="name">What-If Calculator</field>
        <field name="res_model">mea.calculator.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
