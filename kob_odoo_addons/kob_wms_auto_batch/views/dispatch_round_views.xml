<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_dispatch_round_list" model="ir.ui.view">
        <field name="name">wms.dispatch.round.list</field>
        <field name="model">wms.dispatch.round</field>
        <field name="arch" type="xml">
            <list decoration-success="state == 'open'"
                  decoration-muted="state == 'closed'">
                <field name="name"/>
                <field name="label"/>
                <field name="date_open"/>
                <field name="date_close"/>
                <field name="batch_count"/>
                <field name="scan_item_count"/>
                <field name="state" widget="badge"
                       decoration-success="state == 'open'"
                       decoration-muted="state == 'closed'"/>
                <field name="company_id" groups="base.group_multi_company"/>
            </list>
        </field>
    </record>

    <record id="view_dispatch_round_form" model="ir.ui.view">
        <field name="name">wms.dispatch.round.form</field>
        <field name="model">wms.dispatch.round</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_close" type="object"
                            string="Close Round" class="btn-primary"
                            invisible="state != 'open'"
                            confirm="Close this round? The next scan-Out will start a fresh round."/>
                    <button name="action_reopen" type="object"
                            string="Reopen" class="btn-secondary"
                            invisible="state != 'closed'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="open,closed"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_batches" type="object"
                                class="oe_stat_button" icon="fa-cubes">
                            <field name="batch_count" widget="statinfo"
                                   string="Batches"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-spinner" disabled="1">
                            <field name="open_batch_count" widget="statinfo"
                                   string="Open"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-check" disabled="1">
                            <field name="dispatched_batch_count" widget="statinfo"
                                   string="Dispatched"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-hourglass-half" disabled="1">
                            <field name="total_pending" widget="statinfo"
                                   string="Pending"/>
                        </button>
                        <button class="oe_stat_button" icon="fa-percent" disabled="1">
                            <field name="completion_pct" widget="statinfo"
                                   string="Complete"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="name" readonly="1"/></h1>
                    </div>
                    <group>
                        <group>
                            <field name="label" placeholder="Morning / Round 1 ..."/>
                            <field name="date_open"/>
                            <field name="date_close"/>
                        </group>
                        <group>
                            <field name="company_id"
                                   groups="base.group_multi_company"/>
                            <field name="notes"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Per-platform breakdown" name="breakdown">
                            <field name="breakdown_html" widget="html" readonly="1" nolabel="1"/>
                        </page>
                        <page string="Batches" name="batches">
                            <field name="batch_ids" readonly="1">
                                <list decoration-success="state=='dispatched'"
                                      decoration-info="state=='scanning'"
                                      decoration-muted="state=='cancelled'">
                                    <field name="name"/>
                                    <field name="courier_id"/>
                                    <field name="platform" widget="badge"/>
                                    <field name="expected_count"/>
                                    <field name="scanned_done_count"/>
                                    <field name="pending_count"/>
                                    <field name="completion_pct" widget="progressbar"/>
                                    <field name="state" widget="badge"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <record id="view_dispatch_round_search" model="ir.ui.view">
        <field name="name">wms.dispatch.round.search</field>
        <field name="model">wms.dispatch.round</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="label"/>
                <filter name="open" string="Open"
                        domain="[('state','=','open')]"/>
                <filter name="closed" string="Closed"
                        domain="[('state','=','closed')]"/>
                <separator/>
                <filter name="today" string="Today"
                        domain="[('date_open','&gt;=', context_today().strftime('%Y-%m-%d 00:00:00'))]"/>
            </search>
        </field>
    </record>

    <record id="action_dispatch_round" model="ir.actions.act_window">
        <field name="name">Dispatch Rounds</field>
        <field name="res_model">wms.dispatch.round</field>
        <field name="view_mode">list,form</field>
        <field name="context">{"search_default_open": 1}</field>
    </record>
</odoo>
