<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="param_auto_batch_per_platform" model="ir.config_parameter">
        <field name="key">kob_wms_auto_batch.auto_batch_per_platform</field>
        <field name="value">True</field>
    </record>

    <record id="seq_dispatch_round" model="ir.sequence">
        <field name="name">WMS Dispatch Round</field>
        <field name="code">wms.dispatch.round</field>
        <field name="prefix">DR/%(year)s%(month)s%(day)s/</field>
        <field name="padding">3</field>
    </record>
</odoo>
