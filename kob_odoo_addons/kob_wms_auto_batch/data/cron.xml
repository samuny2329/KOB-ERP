<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="cron_auto_open_round" model="ir.cron">
        <field name="name">KOB WMS: Ensure dispatch round is open</field>
        <field name="model_id" ref="model_wms_dispatch_round"/>
        <field name="state">code</field>
        <field name="code">model.cron_auto_open_today()</field>
        <field name="interval_number">15</field>
        <field name="interval_type">minutes</field>
        <field name="active" eval="True"/>
    </record>
</odoo>
