<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <record id="action_assign_to_active_round_server"
            model="ir.actions.server">
        <field name="name">📦 Assign to current dispatch round</field>
        <field name="model_id"
               search="[('model','=','wms.sales.order')]"/>
        <field name="binding_model_id"
               search="[('model','=','wms.sales.order')]"/>
        <field name="binding_type">action</field>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_assign_to_active_round()</field>
    </record>

    <record id="action_clear_dispatch_round_server"
            model="ir.actions.server">
        <field name="name">📦 Clear dispatch round tag</field>
        <field name="model_id"
               search="[('model','=','wms.sales.order')]"/>
        <field name="binding_model_id"
               search="[('model','=','wms.sales.order')]"/>
        <field name="binding_type">action</field>
        <field name="binding_view_types">list,form</field>
        <field name="state">code</field>
        <field name="code">action = records.action_clear_dispatch_round()</field>
    </record>
</odoo>
