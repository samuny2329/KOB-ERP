<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_wms_worker_performance_form" model="ir.ui.view">
        <field name="name">wms.worker.performance.form</field>
        <field name="model">wms.worker.performance</field>
        <field name="arch" type="xml">
            <form string="Worker Performance" create="false" edit="false" delete="false">
                <header/>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_activity_log" type="object"
                                class="oe_stat_button" icon="fa-list-alt">
                            <field name="activity_log_count" widget="statinfo"
                                   string="Activity Log"/>
                        </button>
                        <button name="action_view_sales_orders" type="object"
                                class="oe_stat_button" icon="fa-shopping-cart">
                            <field name="sales_order_count" widget="statinfo"
                                   string="Orders"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <label for="kob_user_id" string="Employee"/>
                        <h1>
                            <field name="kob_user_id" readonly="1"/>
                        </h1>
                        <field name="date" readonly="1"/>
                    </div>
                    <group>
                        <group string="Volume">
                            <field name="pick_count"/>
                            <field name="pack_count"/>
                            <field name="ship_count"/>
                            <field name="box_count"/>
                            <field name="dispatch_count"/>
                            <field name="scan_count"/>
                            <field name="total_actions"/>
                        </group>
                        <group string="Quality &amp; Speed">
                            <field name="uph"/>
                            <field name="pick_errors"/>
                            <field name="pack_errors"/>
                            <field name="total_errors"/>
                            <field name="error_rate" widget="percentage"/>
                            <field name="quality_score" widget="percentage"/>
                            <field name="worker_score"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Update action to include form view -->
    <record id="kob_wms.action_wms_worker_performance" model="ir.actions.act_window">
        <field name="view_mode">list,form,graph,pivot</field>
    </record>
</odoo>
