<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_purchase_form_doc_required" model="ir.ui.view">
        <field name="name">purchase.order.form.doc.required</field>
        <field name="model">purchase.order</field>
        <field name="inherit_id" ref="purchase.purchase_order_form"/>
        <field name="arch" type="xml">
            <xpath expr="//sheet" position="before">
                <field name="attachment_count" invisible="1"/>
                <div class="alert alert-warning text-center mb-0"
                     role="alert"
                     invisible="state != 'draft' or attachment_count > 0">
                    <strong>⚠ ต้องแนบเอกสาร/ใบเสนอราคา ก่อนยืนยัน PO</strong>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
