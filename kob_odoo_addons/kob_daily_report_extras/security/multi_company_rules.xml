<?xml version="1.0" encoding="utf-8"?>
<odoo noupdate="1">
    <!-- Multi-company record rules — show records only for companies the
         user has ticked in the company switcher. -->

    <record id="rule_dispatch_daily_report_mc" model="ir.rule">
        <field name="name">Dispatch Daily Report — multi-company</field>
        <field name="model_id" ref="model_wms_dispatch_daily_report"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="global" eval="True"/>
    </record>

    <record id="rule_wms_daily_report_mc" model="ir.rule">
        <field name="name">WMS Daily Report — multi-company</field>
        <field name="model_id"
               search="[('model','=','wms.daily.report')]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="global" eval="True"/>
    </record>
</odoo>
