# Copy to .env and edit. .env is gitignored.

# ─── Database ───────────────────────────────────────────────────────────
KOB_DB_HOST=localhost
KOB_DB_PORT=5432
KOB_DB_USER=kob
KOB_DB_PASSWORD=kob_dev_password_change_me
KOB_DB_NAME=kob_erp

# ─── Auth ───────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
KOB_SECRET_KEY=dev-secret-replace-in-production-with-strong-random-string
KOB_ACCESS_TOKEN_EXPIRE_MINUTES=60
KOB_REFRESH_TOKEN_EXPIRE_DAYS=14

# ─── App ────────────────────────────────────────────────────────────────
KOB_ENV=development
KOB_DEBUG=true
KOB_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ─── Redis (Celery + cache) ─────────────────────────────────────────────
KOB_REDIS_URL=redis://localhost:6379/0

# ─── MCP Server ─────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000
MCP_API_TOKEN=

# ─── Obsidian Vault (MCP context tools) ────────────────────────────────
OBSIDIAN_VAULT_PATH=/absolute/path/to/your/obsidian/vault

# ─── DeepSeek (context compression — $0.14/M tokens) ───────────────────
# Sign up: platform.deepseek.com  Minimum top-up: $5
DEEPSEEK_API_KEY=sk-...
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# ─── Anthropic sub-agent (Opus 4.7 worker) ──────────────────────────────
# Sign up: console.anthropic.com  Requires Usage Tier 2+
ANTHROPIC_API_KEY=sk-ant-...
SUBAGENT_MODEL=claude-opus-4-7
SUBAGENT_MAX_TOKENS=4096
